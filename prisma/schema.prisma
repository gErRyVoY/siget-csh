// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                Int        @id @default(autoincrement())
  nombre            String
  slug              String     @unique
  tipo              String
  activa            Boolean    @default(true)
  usuarios          Usuario[]
  tickets           Ticket[]
  traslados_origen  Traslado[] @relation("Origen")
  traslados_destino Traslado[] @relation("Destino")
  bloques           Bloque[]

  @@map("empresa")
}

model Rol {
  id                 Int                 @id @default(autoincrement())
  rol                String
  descripcion        String?
  nivel_soporte      String
  activo             Boolean             @default(true)
  atiendeTicketsCsh  Boolean             @default(false)
  atiendeTicketsMkt  Boolean             @default(false)
  usuarios           Usuario[]
  permisos           Permiso[]           @relation()
  permisos_categoria PermisoCategoria[]
  permisos_seccion   PermisoRolSeccion[]

  @@map("rol")
}

model Oferta {
  id          Int       @id @default(autoincrement())
  descripcion String
  carreras    Carrera[]

  @@map("oferta")
}

model Carrera {
  id          Int        @id @default(autoincrement())
  clave       String
  descripcion String
  ofertaId    Int
  activo      Boolean    @default(true)
  oferta      Oferta     @relation(fields: [ofertaId], references: [id])
  traslados   Traslado[]
  bloques     Bloque[]

  @@map("carrera")
}

model Usuario {
  id                      Int                      @id @default(autoincrement())
  mail                    String                   @unique
  nombres                 String
  apellidos               String
  alias                   String?
  image                   String?
  empresaId               Int
  rolId                   Int
  activo                  Boolean                  @default(true)
  vacaciones              Boolean                  @default(false)
  ultimo_login            DateTime                 @default(now())
  horario_disponibilidad  String?
  carga_actual            Int                      @default(0)
  auditor_docs            Boolean                  @default(false)
  auditor_req             Boolean                  @default(false)
  empresa                 Empresa                  @relation(fields: [empresaId], references: [id])
  rol                     Rol                      @relation(fields: [rolId], references: [id])
  asignaciones_categorias AsignacionesCategorias[]
  tickets_solicitados     Ticket[]                 @relation("Solicitante")
  tickets_atendidos       Ticket[]                 @relation("Atiende")
  historial_solicitudes   HistorialSolicitud[]
  traslados_auditor_docs  Traslado[]               @relation("AuditorDocs")
  traslados_auditor_req   Traslado[]               @relation("AuditorReq")
  trl_mail                Boolean                  @default(false)
  trl_coord               Boolean                  @default(false)
  notificaciones_correo   NotificacionesCorreo[]
  logs                    Logs[]
  permisos_seccion        PermisoUsuarioSeccion[]

  @@map("usuario")
}

model Logs {
  id        Int      @id @default(autoincrement())
  accion    String
  fecha     DateTime @default(now())
  detalles  String?
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("logs")
}

model Ciclo {
  id           Int      @id @default(autoincrement())
  ciclo        String
  fecha_inicio DateTime
  fecha_fin    DateTime
  activo       Boolean  @default(false)
  bloques      Bloque[]
  tickets      Ticket[]

  @@map("ciclo")
}

model Bloque {
  id          Int        @id @default(autoincrement())
  clave       String     @unique
  grado       String
  carreraId   Int
  descripcion String
  dias        String
  hora        String
  cicloId     Int
  campusId    Int
  carrera     Carrera    @relation(fields: [carreraId], references: [id])
  ciclo       Ciclo      @relation(fields: [cicloId], references: [id])
  campus      Empresa    @relation(fields: [campusId], references: [id])
  traslados   Traslado[]

  @@map("bloque")
}

model Descuento {
  id          Int        @id @default(autoincrement())
  descripcion String
  monto       Int
  activo      Boolean    @default(true)
  traslados   Traslado[]

  @@map("descuento")
}

model Estatus {
  id                    Int                  @id @default(autoincrement())
  nombre                String
  descripcion           String?
  tickets               Ticket[]
  historial_solicitudes HistorialSolicitud[]

  @@map("estatus")
}

model Categoria {
  id                      Int                      @id @default(autoincrement())
  nombre                  String
  nivel_soporte_requerido String?
  activo                  Boolean                  @default(true)
  tickets                 Ticket[]
  subcategoria_categorias SubcategoriaCategorias[]
  asignaciones_categorias AsignacionesCategorias[]
  roles_permitidos        PermisoCategoria[]

  @@map("categoria")
}

model Subcategoria {
  id                      Int                      @id @default(autoincrement())
  nombre                  String
  parent_subcategoriaId   Int?
  nivel_soporte_requerido String?
  activo                  Boolean                  @default(true)
  parent_subcategoria     Subcategoria?            @relation("SubcategoriaHierarchy", fields: [parent_subcategoriaId], references: [id])
  subcategorias           Subcategoria[]           @relation("SubcategoriaHierarchy")
  tickets                 Ticket[]
  subcategoria_categorias SubcategoriaCategorias[]
  asignaciones_categorias AsignacionesCategorias[]
  roles_permitidos        PermisoCategoria[]

  @@map("subcategoria")
}

model SubcategoriaCategorias {
  categoriaId    Int
  subcategoriaId Int
  activo         Boolean      @default(true)
  categoria      Categoria    @relation(fields: [categoriaId], references: [id])
  subcategoria   Subcategoria @relation(fields: [subcategoriaId], references: [id])

  @@id([categoriaId, subcategoriaId])
  @@map("subcategoria_categorias")
}

model AsignacionesCategorias {
  id             Int      @id @default(autoincrement())
  atiendeId      Int
  categoriaId    Int?
  subcategoriaId Int?
  activo         Boolean  @default(true)
  prioridad      Int      @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  atiende      Usuario       @relation(fields: [atiendeId], references: [id], onDelete: Cascade)
  categoria    Categoria?    @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  subcategoria Subcategoria? @relation(fields: [subcategoriaId], references: [id], onDelete: Cascade)

  @@unique([atiendeId, categoriaId, subcategoriaId])
  @@index([categoriaId, subcategoriaId, activo])
  @@index([atiendeId, activo])
  @@map("asignaciones_categorias")
}

model Ticket {
  id                    Int                    @id @default(autoincrement())
  fechaalta             DateTime               @default(now())
  fechaact              DateTime               @default(now())
  estatusId             Int
  categoriaId           Int
  subcategoriaId        Int?
  solicitanteId         Int
  atiendeId             Int?
  prioridad             String
  descripcion           String?
  afectado_clave        String?
  afectado_nombre       String?
  empresaId             Int
  cicloId               Int?
  archivado             Boolean                @default(false)
  archivos              String?
  estatus               Estatus                @relation(fields: [estatusId], references: [id])
  categoria             Categoria              @relation(fields: [categoriaId], references: [id])
  subcategoria          Subcategoria?          @relation(fields: [subcategoriaId], references: [id])
  solicitante           Usuario                @relation("Solicitante", fields: [solicitanteId], references: [id])
  atiende               Usuario?               @relation("Atiende", fields: [atiendeId], references: [id])
  empresa               Empresa                @relation(fields: [empresaId], references: [id])
  ciclo                 Ciclo?                 @relation(fields: [cicloId], references: [id])
  traslados             Traslado[]
  historial_solicitudes HistorialSolicitud[]
  notificaciones_correo NotificacionesCorreo[]

  @@map("ticket")
}

model PlanPago {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  activo      Boolean    @default(true)
  traslados   Traslado[]

  @@map("plan_pago")
}

model Traslado {
  id             Int     @id @default(autoincrement())
  ticketId       Int     @unique
  folio          String  @unique
  matricula      String
  alumno         String
  origenId       Int
  destinoId      Int
  carreraId      Int
  descuentoId    Int
  bloqueId       Int?
  bloque_nombre  String?
  actualizacion  Boolean @default(false)
  planpagoId     Int?
  auditor_docsId Int?
  auditor_reqId  Int?
  especial       Boolean @default(false)
  nuevo_ingreso  Boolean @default(false)
  mail           String?
  mail_escuela   String?
  telefono       String?
  tel_movil      String?

  // Validacion Auditor Documentos
  validacion_docs  Boolean @default(false)
  descripcion_docs String?

  // Validacion Auditor Requisitos (Calificaciones y Estado de Cuenta)
  validacion_calif   Boolean @default(false)
  descripcion_calif  String?
  validacion_edocta  Boolean @default(false)
  descripcion_edocta String?

  ticket       Ticket    @relation(fields: [ticketId], references: [id])
  origen       Empresa   @relation("Origen", fields: [origenId], references: [id])
  destino      Empresa   @relation("Destino", fields: [destinoId], references: [id])
  carrera      Carrera   @relation(fields: [carreraId], references: [id])
  descuento    Descuento @relation(fields: [descuentoId], references: [id])
  bloque       Bloque?   @relation(fields: [bloqueId], references: [id])
  planpago     PlanPago? @relation(fields: [planpagoId], references: [id])
  auditor_docs Usuario?  @relation("AuditorDocs", fields: [auditor_docsId], references: [id])
  auditor_req  Usuario?  @relation("AuditorReq", fields: [auditor_reqId], references: [id])

  @@map("traslado")
}

model HistorialSolicitud {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  estatusId    Int
  usuarioId    Int
  fecha_cambio DateTime @default(now())
  comentario   String?
  cambios      String?
  archivos     String?
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  estatus      Estatus  @relation(fields: [estatusId], references: [id])
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("historial_solicitud")
}

model PlantillaCorreo {
  id                    Int                    @id @default(autoincrement())
  nombre                String
  contenido             String?
  tipo                  String
  activo                Boolean                @default(false)
  notificaciones_correo NotificacionesCorreo[]

  @@map("plantilla_correo")
}

model NotificacionesCorreo {
  id             Int             @id @default(autoincrement())
  ticketId       Int
  destinatarioId Int
  fecha_envio    DateTime        @default(now())
  plantillaId    Int
  estatus        String
  mensaje_error  String?
  ticket         Ticket          @relation(fields: [ticketId], references: [id])
  destinatario   Usuario         @relation(fields: [destinatarioId], references: [id])
  plantilla      PlantillaCorreo @relation(fields: [plantillaId], references: [id])

  @@map("notificaciones_correo")
}

model Permiso {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?
  roles       Rol[]   @relation()

  @@map("permiso")
}

model PermisoCategoria {
  id             Int      @id @default(autoincrement())
  rolId          Int
  categoriaId    Int?
  subcategoriaId Int?
  activo         Boolean  @default(true)
  prioridad      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rol          Rol           @relation(fields: [rolId], references: [id], onDelete: Cascade)
  categoria    Categoria?    @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  subcategoria Subcategoria? @relation(fields: [subcategoriaId], references: [id], onDelete: Cascade)

  @@unique([rolId, categoriaId, subcategoriaId])
  @@index([categoriaId, subcategoriaId, activo])
  @@index([rolId, activo])
  @@map("permiso_categoria")
}

// ==========================================
// Módulo de Permisos por Secciones (RBAC)
// ==========================================

model Seccion {
  id               Int                     @id @default(autoincrement())
  nombre           String
  identificador    String                  @unique
  grupo            String?
  subgrupo         String?
  descripcion      String?
  activo           Boolean                 @default(true)
  permisos_rol     PermisoRolSeccion[]
  permisos_usuario PermisoUsuarioSeccion[]

  @@map("seccion")
}

model PermisoRolSeccion {
  id        Int      @id @default(autoincrement())
  rolId     Int
  seccionId Int
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  seccion Seccion @relation(fields: [seccionId], references: [id], onDelete: Cascade)

  @@unique([rolId, seccionId])
  @@index([rolId, activo])
  @@map("permiso_rol_seccion")
}

model PermisoUsuarioSeccion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  seccionId Int
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  seccion Seccion @relation(fields: [seccionId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, seccionId])
  @@index([usuarioId, activo])
  @@map("permiso_usuario_seccion")
}
