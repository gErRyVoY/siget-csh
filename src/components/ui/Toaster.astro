---
// Componente Toaster para sistema personalizado
---

<script>
    import { toast } from "@/lib/toast";

    function initToaster() {
        // Exponer toast globalmente
        (window as any).toast = toast;
        console.log("[Toast] Sistema personalizado inicializado");
    }

    document.addEventListener("astro:page-load", initToaster);
</script>
