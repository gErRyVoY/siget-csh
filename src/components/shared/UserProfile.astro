---
import type { Session } from "@auth/core/types";
import MoreHorizontalIcon from "@/components/icons/MoreHorizontalIcon.astro";
import LogoutIcon from "@/components/icons/LogoutIcon.astro";
import { SignOut } from "auth-astro/components";

interface Props {
    session: Session | null;
}

const { session } = Astro.props;
const user = session?.user;
const userEmpresa = user?.empresa?.nombre;
const userName: string | null = (user as any)?.name ?? null;
const userEmail: string | null = (user as any)?.email ?? null;

// Determinar si el usuario atiende tickets (CSH o Mkt)
const atiendeTicketsCsh: boolean = (user?.rol as any)?.atiendeTicketsCsh ?? false;
const atiendeTicketsMkt: boolean = (user?.rol as any)?.atiendeTicketsMkt ?? false;
const atiendeTickets = atiendeTicketsCsh || atiendeTicketsMkt;

// Alias: si está definido y no está vacío (solo espacios), usarlo
const rawAlias = user?.alias ?? "";
const alias = rawAlias.trim().length > 0 ? rawAlias.trim() : null;

// Obtener iniciales del usuario si no hay imagen de perfil
const initials =
    (alias ?? userName)
        ?.split(" ")
        .map((n: string) => n[0])
        .join("")
        .substring(0, 2)
        .toUpperCase() || "";

// Formatear el nombre según la cantidad de partes
const formattedName = (() => {
    if (!userName) return "Usuario";
    const parts = userName.split(" ");
    const numParts = parts.length;
    if (numParts === 3) return `${parts[0]} ${parts[1]}`;
    if (numParts === 4) return `${parts[0]} ${parts[2]}`;
    if (numParts > 1) return `${parts[0]} ${parts[numParts - 1]}`;
    return userName;
})();

// Nombre a mostrar: alias si existe, si no el formattedName
const displayName = alias ?? formattedName;

// Descomponer el email en usuario y dominio
const [username, domain] = userEmail?.split("@") ?? ["", ""];

// Nombre del rol (solo primera letra mayúscula)
const rolNombre = user?.rol?.rol ?? "";
const rolDisplay = rolNombre.charAt(0).toUpperCase() + rolNombre.slice(1).toLowerCase();

// Vacation status
const enVacaciones = user?.vacaciones ?? false;
---

<div id="user-profile-wrapper" class="relative">
    <!-- Menú desplegable del usuario -->
    <div
        id="user-menu"
        data-open="false"
        class="absolute bottom-full left-2 mb-3 w-60 p-1.5 rounded-md
                bg-popover text-popover-foreground border border-border shadow-lg
                transition-all duration-200 ease-in-out
                transform-gpu origin-bottom
                opacity-0 scale-95 data-[open=true]:opacity-100 data-[open=true]:scale-100
                pointer-events-none data-[open=true]:pointer-events-auto"
    >
        {atiendeTickets ? (
            /* === MENU PARA USUARIOS QUE ATIENDEN TICKETS === */
            <>
                {/* Editar perfil link */}
                <a
                    href="/user/perfil"
                    class="flex items-center gap-2 w-full px-2 py-2 text-sm rounded-sm hover:bg-accent transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    <span>Editar perfil</span>
                </a>

                {/* Toggle de Vacaciones */}
                <div class="flex items-center justify-between px-2 py-2 rounded-sm hover:bg-accent transition-colors">
                    <span class="text-sm">Vacaciones</span>
                    <label class="relative inline-flex h-5 w-9 cursor-pointer items-center justify-center rounded-full" title="Cambiar estatus de vacaciones">
                        <input
                            type="checkbox"
                            id="vacation-toggle-menu"
                            class="sr-only peer"
                            checked={enVacaciones}
                        />
                        <div class="h-5 w-9 absolute rounded-full transition-all opacity-80 peer-checked:opacity-100 bg-muted-foreground peer-checked:bg-secondary" />
                        <div class="absolute top-[2px] left-[2px] bg-white border border-gray-300 rounded-full h-4 w-4 transition-transform peer-checked:translate-x-[16px] peer-checked:border-white z-10" />
                    </label>
                </div>

                <div class="h-px bg-border my-1"></div>

                <SignOut
                    class="flex items-center gap-3 w-full px-2 py-1.5 text-sm rounded-sm text-destructive hover:bg-destructive/10"
                >
                    <LogoutIcon class="h-4 w-4" />
                    <span>Cerrar Sesión</span>
                </SignOut>
            </>
        ) : (
            /* === MENU PARA USUARIOS NORMALES === */
            <>
                <div class="flex p-1">
                    {
                        user?.image ? (
                            <img
                                src={user.image}
                                alt={displayName}
                                class="w-10 h-10 rounded-full"
                                referrerpolicy="no-referrer"
                            />
                        ) : (
                            <div class="w-10 h-10 rounded-full bg-muted flex items-center justify-center font-bold text-muted-foreground">
                                {initials}
                            </div>
                        )
                    }
                    <div class="px-2 py-1.5">
                        <p class="text-sm font-semibold">{formattedName}</p>
                        <p class="text-xs text-muted-foreground">{username}</p>
                        <p class="text-xs text-muted-foreground">@{domain}</p>
                    </div>
                </div>
                <div class="h-px bg-border my-1"></div>
                <SignOut
                    class="flex items-center gap-3 w-full px-2 py-1.5 text-sm rounded-sm text-destructive hover:bg-destructive/10"
                >
                    <LogoutIcon class="h-4 w-4" />
                    <span>Cerrar Sesión</span>
                </SignOut>
            </>
        )}
    </div>

    <!-- Botón principal que muestra el perfil y activa el menú -->
    <button
        id="user-menu-trigger"
        type="button"
        class="group w-full flex items-center gap-3 p-2 rounded-md hover:bg-accent cursor-pointer"
    >
        {
            user?.image ? (
                <img
                    src={user.image}
                    alt={displayName}
                    class="w-10 h-10 rounded-full"
                    referrerpolicy="no-referrer"
                />
            ) : (
                <div class="w-10 h-10 rounded-full bg-muted flex items-center justify-center font-bold text-muted-foreground">
                    {initials}
                </div>
            )
        }
        <div class="text-left group-data-[sidebar-collapsed=true]:hidden">
            <p class="text-sm font-semibold">{displayName}</p>
            {atiendeTickets ? (
                <>
                    <p class="text-xs text-muted-foreground">{rolDisplay}</p>
                    <p class="text-xs text-muted-foreground uppercase">{userEmpresa}</p>
                </>
            ) : (
                <>
                    <p class="text-xs text-muted-foreground">{rolDisplay}</p>
                    <p class="text-xs text-muted-foreground uppercase">{userEmpresa}</p>
                </>
            )}
        </div>
        <div class="ml-auto group-data-[sidebar-collapsed=true]:hidden">
            <MoreHorizontalIcon class="h-5 w-5" />
        </div>
    </button>
</div>

<script>
    import { toast } from "@/lib/toast";

    function initUserProfileMenu() {
        const wrapper = document.getElementById("user-profile-wrapper");
        const trigger = document.getElementById("user-menu-trigger");
        const menu = document.getElementById("user-menu");

        if (!wrapper || !trigger || !menu) return;

        const toggleMenu = (force?: boolean) => {
            const isOpen = menu.dataset.open === "true";
            const newState = force === undefined ? !isOpen : force;
            menu.dataset.open = String(newState);
        };

        trigger.addEventListener("click", (e) => {
            e.stopPropagation();
            toggleMenu();
        });

        const closeMenu = (e: MouseEvent | KeyboardEvent) => {
            if (e instanceof KeyboardEvent && e.key !== "Escape") return;
            if (wrapper && !wrapper.contains(e.target as Node)) {
                toggleMenu(false);
            }
        };

        document.addEventListener("click", closeMenu);
        document.addEventListener("keydown", closeMenu);

        // Vacation toggle in dropdown menu
        const vacationToggle = document.getElementById("vacation-toggle-menu") as HTMLInputElement | null;
        vacationToggle?.addEventListener("change", async () => {
            const newVal = vacationToggle.checked;
            try {
                const res = await fetch("/api/user/profile", {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ vacaciones: newVal }),
                });
                if (!res.ok) throw new Error((await res.json()).message);
                toast.success(newVal ? "Estatus de vacaciones activado" : "Estatus de vacaciones desactivado");
                
                // Sync profile page toggle if we are on the profile page
                if (window.location.pathname === "/user/perfil") {
                    const profileToggle = document.getElementById("vacaciones") as HTMLInputElement | null;
                    const profileText = document.getElementById("vacaciones-status-text");
                    if (profileToggle) profileToggle.checked = newVal;
                    if (profileText) profileText.textContent = newVal ? "De vacaciones" : "En oficina";
                }
            } catch (err: any) {
                vacationToggle.checked = !newVal;
                toast.error(err.message || "Error al actualizar estatus");
            }
        });
    }

    document.addEventListener("astro:page-load", initUserProfileMenu);
</script>
