---
interface Props {
    title: string;
    value: string;
    description: string;
    color?: string;
}

const { title, value, description, color = "var(--card)" } = Astro.props;
---

<div
    class="text-white p-6 rounded-lg shadow-md border border-transparent dark:border-white/10"
    style={`background-color: ${color}`}
>
    <span class="text-sm font-medium opacity-90">{title}</span>
    <p class="text-3xl font-bold mt-2">{value}</p>
    <p class="text-xs opacity-75 mt-2">{description}</p>
</div>
