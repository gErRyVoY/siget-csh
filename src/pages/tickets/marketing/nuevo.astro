---
import MainLayout from "@/layouts/MainLayout.astro";
import categoriesData from "@/data/categories.json";
import { getSession } from "auth-astro/server";

const session = await getSession(Astro.request);
const user = session?.user;

if (!user) {
    return Astro.redirect("/login");
}

// Filtrar solo la categoría Marketing (ID 12)
const marketingCategory = categoriesData.find((c) => c.id === 12);
---

<MainLayout title="Nuevo Ticket de Marketing">
    <div class="max-w-5xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
            <h1 class="text-3xl font-bold text-foreground">
                Nuevo Ticket de Marketing
            </h1>
            <a
                href="/tickets/marketing/usuario"
                class="text-sm text-primary hover:underline"
            >
                Volver a Mis Tickets
            </a>
        </div>

        <p class="text-muted-foreground">
            Selecciona el área de Marketing para tu solicitud.
        </p>

        <div
            id="marketing-wizard"
            class="flex flex-row gap-4 overflow-x-auto pb-4"
        >
            <!-- La primera columna mostrará las subcategorías directas de Marketing (Diseño, Redes, Video, etc.) -->
        </div>

        <!-- Área de Descripción y Envío -->
        <div
            id="descripcion-area"
            class="max-w-4xl mt-4 p-4 bg-card border rounded-lg hidden"
        >
            <h3
                id="descripcion-title"
                class="font-semibold mb-2 text-card-foreground"
            >
                Describe tu solicitud
            </h3>
            <form id="ticket-form">
                <!-- Campos dinámicos para datos del afectado (si aplica) -->
                <div
                    id="afectado-fields"
                    class="hidden grid-cols-1 md:grid-cols-2 gap-4 mb-4"
                >
                    <div>
                        <label
                            id="lbl-clave"
                            for="afectado_clave"
                            class="block text-sm font-medium text-foreground mb-1"
                            >Clave / Matrícula</label
                        >
                        <input
                            type="text"
                            id="afectado_clave"
                            name="afectado_clave"
                            class="w-full rounded-md border-border bg-input p-2 text-sm focus:outline-none focus:ring-1 focus:ring-secondary focus:border-secondary"
                        />
                    </div>
                    <div>
                        <label
                            for="afectado_nombre"
                            class="block text-sm font-medium text-foreground mb-1"
                            >Nombre Completo</label
                        >
                        <input
                            type="text"
                            id="afectado_nombre"
                            name="afectado_nombre"
                            class="w-full rounded-md border-border bg-input p-2 text-sm focus:outline-none focus:ring-1 focus:ring-secondary focus:border-secondary"
                        />
                    </div>
                </div>

                <textarea
                    id="descripcion"
                    name="descripcion"
                    rows="4"
                    class="mt-1 block w-full rounded-md border-border bg-input p-2 accent-secondary focus:outline-none focus:ring-1 focus:ring-secondary focus:border-secondary"
                    placeholder="Detalla tu requerimiento..."></textarea>
                <div class="flex justify-end pt-4">
                    <button
                        type="submit"
                        id="submit-ticket"
                        class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled
                    >
                        Crear Ticket
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Pasamos solo la data de marketing -->
    <script
        id="marketing-data"
        type="application/json"
        is:inline
        set:html={JSON.stringify(marketingCategory)}
    />
</MainLayout>

<script src="../../../scripts/init-nuevo-ticket-marketing.ts"></script>
