---
import MainLayout from "@/layouts/MainLayout.astro";
import { getSession } from "auth-astro/server";
import { prisma } from "@/lib/db";
import {
    type Ticket,
    type Estatus,
    type Usuario,
    Prioridad,
    type HistorialSolicitud,
    type Subcategoria,
} from "@prisma/client";

const { id } = Astro.params;
if (!id) {
    return Astro.redirect("/404");
}

const ticketId = parseInt(id, 10);

const S3_BUCKET_URL = `https://${import.meta.env.S3_BUCKET_NAME}.s3.${import.meta.env.S3_REGION}.amazonaws.com`;

const ALLOWED_STATUSES = [
    "Nuevo",
    "En progreso",
    "En espera",
    "Solucionado",
    "Cancelado",
    "Duplicado",
];
const statusColors: { [key: string]: string } = {
    Nuevo: "#a1a1aa",
    "En progreso": "#3b82f6",
    "En espera": "#38bdf8",
    Solucionado: "#84cc16",
    Cancelado: "#dc2626",
    Duplicado: "#171717",
};

const [ticket, ticketHistory, cshSupportUsers, cshAuditorDocs, cshAuditorReq] =
    await Promise.all([
        prisma.ticket.findUnique({
            where: { id: ticketId },
            include: {
                estatus: true,
                categoria: true,
                subcategoria: true,
                solicitante: { include: { empresa: true } },
                atiende: true,
                empresa: true,
                traslados: {
                    include: {
                        origen: true,
                        destino: true,
                        carrera: true,
                        descuento: true,
                        bloque: true,
                    },
                },
            },
        }),
        prisma.historialSolicitud.findMany({
            where: { ticketId: ticketId },
            include: {
                usuario: { select: { nombres: true, apellidos: true } },
                estatus: { select: { nombre: true } },
            },
            orderBy: { fecha_cambio: "desc" },
        }),
        // Fetch Support Agents for CSH (ID 15)
        // We'll filter by specific roles in valid logic later or fetch all relevant roles
        // For now, let's just fetch active users from CSH to filter in memory or specific roles if known.
        // User said: "rolId tenga uno de los que estan permitidos".
        // Usually S-1, S-2, S-3 (IDs 1, 2, 3), Developer (4), Coordinator (8), Director (9)?
        // Let's assume standard support roles for now: 1, 2, 3, 4, 8, 9.
        prisma.usuario.findMany({
            where: {
                empresaId: 15,
                activo: true,
                // roles: S-1, S-2, S-3, Dev, Coord, Director (Adjust IDs as per seed)
                rolId: { in: [1, 2, 3, 4, 8, 9] },
            },
        }),
        // Fetch Auditor Docs
        prisma.usuario.findMany({
            where: { empresaId: 15, activo: true, auditor_docs: true },
        }),
        // Fetch Auditor Req
        prisma.usuario.findMany({
            where: { empresaId: 15, activo: true, auditor_req: true },
        }),
    ]);

if (!ticket) {
    return Astro.redirect("/404");
}

const session = await getSession(Astro.request);
const PRIVILEGED_ROLES = [1, 2, 3, 4, 5, 6, 15];
const isPrivileged = session?.user
    ? PRIVILEGED_ROLES.includes(session.user.rol?.id ?? -1)
    : false;
const isReadOnly = false; // Reverted: Allow editing for all statuses

const breadcrumbPath = [ticket.categoria.nombre];
if (ticket.subcategoria) {
    let currentSub: Subcategoria | null = ticket.subcategoria;
    const subPath = [];
    while (currentSub) {
        subPath.unshift(currentSub.nombre);
        if (currentSub.parent_subcategoriaId) {
            currentSub = await prisma.subcategoria.findUnique({
                where: { id: currentSub.parent_subcategoriaId },
            });
        } else {
            currentSub = null;
        }
    }
    breadcrumbPath.push(...subPath);
}

let statuses: Estatus[] = [];
let agents: Usuario[] = [];
const priorities = Object.values(Prioridad);

// Fetch statuses for everyone
statuses = await prisma.estatus.findMany({
    where: { nombre: { in: ALLOWED_STATUSES } },
});

if (isPrivileged) {
    // Privileged users see all agents
    agents = await prisma.usuario.findMany({
        where: { rolId: { in: PRIVILEGED_ROLES }, activo: true },
    });
} else {
    // Regular users only see the current agent (if any)
    if (ticket.atiende) {
        agents = [ticket.atiende];
    }

    // Regular users cannot select 'Nuevo' if it's not currently 'Nuevo'
    if (ticket.estatus.nombre !== "Nuevo") {
        statuses = statuses.filter((s) => s.nombre !== "Nuevo");
    }
}

const parseFileName = (key: string) => {
    if (!key) return "archivo-desconocido";
    return key.split("/").pop()?.split("-").slice(1).join("-") || key;
};

const source = Astro.url.searchParams.get("source");
const backLink =
    source === "mis-tickets" ? "/tickets/soporte/usuario" : "/tickets/soporte";

let afectadoLabel = "Clave";
let nombreLabel = "Nombre del Afectado";

if (ticket.categoriaId === 1) {
    afectadoLabel = "Matrícula";
    nombreLabel = "Nombre del Alumno";
} else if (ticket.categoriaId === 2) {
    afectadoLabel = "Folio";
    nombreLabel = "Nombre del Aspirante";
} else if (ticket.categoriaId === 3) {
    nombreLabel = "Nombre del Colaborador";
} else if (ticket.categoriaId === 4) {
    nombreLabel = "Nombre del Docente";
}

const fieldMap: Record<string, string> = {
    prioridad: "Prioridad",
    estatusId: "Estatus",
    atiendeId: "Atiende",
    archivado: "Archivado",
    afectado_clave: afectadoLabel,
    afectado_nombre: nombreLabel,
    descripcion: "Descripción",
};

const isTraslado = ticket.traslados && ticket.traslados.length > 0;
const traslado = isTraslado ? ticket.traslados[0] : null;
---

<MainLayout title={`Ticket #${ticket.id}`}>
    <style>
        @keyframes flash {
            0% {
                background-color: transparent;
            }
            50% {
                background-color: var(--muted);
            }
            100% {
                background-color: transparent;
            }
        }
        .flash-animation {
            animation: flash 1s ease-in-out;
        }
        @media (max-width: 1119px) {
            #action-buttons-container.has-files {
                flex-direction: column;
                align-items: end;
                width: calc(2 / 5 * 100%);
            }
            #action-buttons-container.has-files #submit-button {
                order: 1;
            }
            #action-buttons-container.has-files #upload-files-button {
                order: 2;
            }
            #action-buttons-container.has-files #delete-files-button {
                order: 3;
            }
            #action-buttons-container.has-files #help-text {
                order: 4;
                text-align: right;
            }
        }
    </style>
    <div class="max-w-4xl mx-auto">
        <div class="mb-4 text-sm text-muted-foreground">
            {breadcrumbPath.join(" > ")}
        </div>

        <form id="edit-ticket-form">
            <div class="bg-card border border-secondary rounded-lg p-4 mb-6">
                {isTraslado && traslado ? (
                    /* --- VISTA TRASLADOS --- */
                    <div class="space-y-6">
                        {/* Header: Back Button & Status */}
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                            <a
                                href={backLink}
                                class="bg-muted-foreground text-white hover:bg-muted-foreground/90 px-6 py-2 rounded-md text-sm font-semibold transition-colors shrink-0"
                            >
                                Volver a la lista
                            </a>
                            <div class="flex items-center gap-4 w-full md:w-auto justify-end">
                                <div>
                                    <label for="prioridad" class="block text-xs font-medium text-muted-foreground text-right mb-1">Prioridad</label>
                                    <select
                                        id="prioridad"
                                        name="prioridad"
                                        class="block w-32 rounded-md border-border bg-input p-2 text-sm"
                                    >
                                        {priorities.map((p) => (
                                            <option value={p} selected={p === ticket.prioridad}>{p}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label for="estatusId" class="block text-xs font-medium text-muted-foreground text-right mb-1">Estatus</label>
                                    <select
                                        id="estatusId"
                                        name="estatusId"
                                        class="block w-40 rounded-md border-border p-2 text-sm font-medium"
                                        style={`background-color: ${(ticket.estatus.nombre === "Nuevo" && !ticket.atiendeId) ? "var(--primary)" : (statusColors[ticket.estatus.nombre] || "#a1a1aa")}; color: white;`}
                                    >
                                        {statuses.map((s) => {
                                            let label = s.nombre;
                                            let color = statusColors[s.nombre] || "#a1a1aa";
                                            if (s.nombre === "Nuevo" && !ticket.atiendeId) {
                                                label = "Sin asignar";
                                                color = "var(--primary)";
                                            }
                                            return (
                                                <option 
                                                    value={s.id} 
                                                    selected={s.id === ticket.estatusId} 
                                                    style={`background-color: ${color}; color: white;`}
                                                >
                                                    {label}
                                                </option>
                                            );
                                        })}
                                    </select>
                                </div>
                            </div>
                        </div>

                        {/* Student Info */}
                        <div class="grid grid-cols-3 gap-4 border-b border-border pb-4">
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">Matrícula</label>
                                <p class="text-base font-semibold">{traslado.matricula}</p>
                            </div>
                            <div class="col-span-2">
                                <label class="block text-xs font-medium text-muted-foreground">Nombre del Alumno</label>
                                <p class="text-base font-semibold">{traslado.alumno}</p>
                            </div>
                        </div>

                        {/* Campus Info */}
                        <div class="grid grid-cols-2 gap-4 border-b border-border pb-4">
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">Campus Origen</label>
                                <p class="text-sm">{traslado.origen?.nombre}</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">Campus Destino</label>
                                <p class="text-sm font-bold text-primary">{traslado.destino?.nombre}</p>
                            </div>
                        </div>

                        {/* Career */}
                        <div class="border-b border-border pb-4">
                            <label class="block text-xs font-medium text-muted-foreground">Carrera</label>
                            <p class="text-sm">{traslado.carrera?.descripcion}</p>
                        </div>

                        {/* Admission, Discount & Block */}
                        <div class="grid grid-cols-3 gap-4 border-b border-border pb-4 items-center">
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">¿Es nuevo ingreso?</label>
                                <p class="text-sm font-semibold">{traslado.nuevo_ingreso ? 'Sí' : 'No'}</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">¿Tiene descuento?</label>
                                <p class="text-sm">{traslado.descuento ? `${traslado.descuento.descripcion} (Sí)` : 'No'}</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">Bloque Sugerido</label>
                                <div class="flex items-center gap-2">
                                    <p class="text-sm">{traslado.bloque_nombre || 'N/A'}</p>
                                    {(traslado.bloqueId || traslado.bloque) && (
                                        <button 
                                            type="button"
                                            class="text-xs text-blue-600 hover:underline"
                                            onclick={`document.getElementById('bloque-info-modal').showModal()`}
                                        >
                                            Ver información
                                        </button>
                                    )}
                                </div>
                            </div>
                        </div>
                        
                        {/* Hidden Modal for Block Info (Simple HTML dialog) */}
                        {traslado.bloque && (
                            <dialog id="bloque-info-modal" class="p-6 rounded-lg border border-border bg-card shadow-xl backdrop:bg-black/50">
                                <h3 class="font-bold text-lg mb-4">Información del Bloque</h3>
                                <div class="space-y-2 text-sm">
                                    <p><strong>Clave:</strong> {traslado.bloque.clave}</p>
                                    <p><strong>Descripción:</strong> {traslado.bloque.descripcion}</p>
                                    <p><strong>Días:</strong> {traslado.bloque.dias}</p>
                                    <p><strong>Horas:</strong> {traslado.bloque.hora}</p>
                                </div>
                                <div class="mt-6 flex justify-end">
                                    <button type="button" class="px-4 py-2 bg-muted rounded hover:bg-muted/80" onclick="this.closest('dialog').close()">Cerrar</button>
                                </div>
                            </dialog>
                        )}


                        {/* 3-Column Assignment Section */}
                        <div class="grid grid-cols-1 custom-lg:grid-cols-3 gap-4">
                            <style>
                                @media (min-width: 1100px) {
                                    .custom-lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
                                }
                            </style>
                            
                            {/* Col 1: Atiende */}
                            <div class="space-y-2 bg-muted/10 p-3 rounded-md border border-border/50">
                                <h4 class="font-semibold text-sm border-b border-border pb-2 mb-2">Atiende</h4>
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-muted-foreground">Ingeniero Asignado:</span>
                                    {isPrivileged ? (
                                        <select name="atiendeId" class="w-full rounded-md border-border bg-input p-1 text-sm">
                                            <option value="">Sin asignar</option>
                                            {cshSupportUsers.map(u => (
                                                <option value={u.id} selected={u.id === ticket.atiendeId}>{u.nombres} {u.apellidos}</option>
                                            ))}
                                        </select>
                                    ) : (
                                        <p class="text-sm font-medium">{ticket.atiende ? `${ticket.atiende.nombres} ${ticket.atiende.apellidos}` : 'Sin asignar'}</p>
                                    )}
                                </div>
                            </div>

                            {/* Col 2: Rev. Documentos */}
                            <div class="space-y-2 bg-muted/10 p-3 rounded-md border border-border/50">
                                <h4 class="font-semibold text-sm border-b border-border pb-2 mb-2">Rev. Documentos</h4>
                                
                                {/* Row 1: Assign Auditor */}
                                <div class="flex items-center gap-2 mb-2">
                                    <input type="checkbox" disabled checked={!!traslado.auditor_docsId} class="rounded text-muted-foreground" />
                                    <div class="w-full">
                                        <label class="block text-xs text-muted-foreground">Auditor:</label>
                                        <select name="auditor_docsId" class="w-full rounded-md border-border bg-input p-1 text-sm">
                                            <option value="">Sin asignar</option>
                                            {cshAuditorDocs.map(u => (
                                                <option value={u.id} selected={u.id === traslado.auditor_docsId}>{u.nombres} {u.apellidos}</option>
                                            ))}
                                        </select>
                                    </div>
                                </div>

                                {/* Row 2: Validation */}
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2">
                                        <input type="checkbox" name="validacion_docs" id="validacion_docs" checked={traslado.validacion_docs} class="rounded" />
                                        <label for="validacion_docs" class="text-xs font-medium">Documentación Correcta</label>
                                    </div>
                                    <textarea name="descripcion_docs" rows="2" placeholder="Comentarios..." class="w-full text-xs rounded border-border bg-input p-1">{traslado.descripcion_docs}</textarea>
                                </div>
                            </div>

                            {/* Col 3: Rev. Adeudos */}
                            <div class="space-y-2 bg-muted/10 p-3 rounded-md border border-border/50">
                                <h4 class="font-semibold text-sm border-b border-border pb-2 mb-2">Rev. Adeudos</h4>
                                
                                {/* Row 1: Assign Auditor */}
                                <div class="flex flex-col gap-1 mb-3">
                                    <label class="text-xs text-muted-foreground">Auditor:</label>
                                    <select name="auditor_reqId" class="w-full rounded-md border-border bg-input p-1 text-sm">
                                        <option value="">Sin asignar</option>
                                        {cshAuditorReq.map(u => (
                                            <option value={u.id} selected={u.id === traslado.auditor_reqId}>{u.nombres} {u.apellidos}</option>
                                        ))}
                                    </select>
                                </div>

                                {/* Row 2a: Edocta */}
                                <div class="space-y-1 mb-2">
                                    <div class="flex items-center gap-2">
                                        <input type="checkbox" name="validacion_edocta" id="validacion_edocta" checked={traslado.validacion_edocta} class="rounded" />
                                        <label for="validacion_edocta" class="text-xs font-medium">Sin Adeudo Financiero</label>
                                    </div>
                                    <textarea name="descripcion_edocta" rows="1" placeholder="Comentarios Edocta..." class="w-full text-xs rounded border-border bg-input p-1">{traslado.descripcion_edocta}</textarea>
                                </div>

                                {/* Row 2b: Calif */}
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2">
                                        <input type="checkbox" name="validacion_calif" id="validacion_calif" checked={traslado.validacion_calif} class="rounded" />
                                        <label for="validacion_calif" class="text-xs font-medium">Sin Adeudo Escolar</label>
                                    </div>
                                    <textarea name="descripcion_calif" rows="1" placeholder="Comentarios Calif..." class="w-full text-xs rounded border-border bg-input p-1">{traslado.descripcion_calif}</textarea>
                                </div>
                            </div>
                        </div>

                    </div>
                ) : (
                    /* --- VISTA NORMAL (EXISTENTE) --- */
                    <>
                        <div class="flex justify-between items-center mb-4">
                            <p class="text-lg font-semibold">
                                {ticket.solicitante.nombres} {ticket.solicitante.apellidos}
                            </p>
                            <a
                                href={backLink}
                                class="bg-muted text-muted-foreground hover:bg-muted/80 px-6 py-2 rounded-md text-sm font-semibold transition-colors"
                            >
                                Volver a la lista
                            </a>
                        </div>
                        <div class="space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-xs font-medium text-muted-foreground">Empresa</label>
                                    <p class="mt-1">{ticket.empresa.nombre}</p>
                                </div>
                                <div>
                                    <label for="prioridad" class="block text-xs font-medium text-muted-foreground">Prioridad</label>
                                    {/* ... Existing Select ... */}
                                    <select id="prioridad" name="prioridad" class="mt-1 block w-full rounded-md border-border bg-input p-2 text-sm">
                                        {priorities.map((p) => (
                                            <option value={p} selected={p === ticket.prioridad}>{p}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label for="estatusId" class="block text-xs font-medium text-muted-foreground">Estatus</label>
                                    <select 
                                        id="estatusId" 
                                        name="estatusId" 
                                        class="mt-1 block w-full rounded-md border-border p-2 text-sm"
                                        style={`background-color: ${(ticket.estatus.nombre === "Nuevo" && !ticket.atiendeId) ? "var(--primary)" : (statusColors[ticket.estatus.nombre] || "#a1a1aa")}; color: white;`}
                                    >
                                        {statuses.map((s) => {
                                            let label = s.nombre;
                                            let color = statusColors[s.nombre] || "#a1a1aa";
                                            if (s.nombre === "Nuevo" && !ticket.atiendeId) {
                                                label = "Sin asignar";
                                                color = "var(--primary)";
                                            }
                                            return (
                                                <option 
                                                    value={s.id} 
                                                    selected={s.id === ticket.estatusId} 
                                                    style={`background-color: ${color}; color: white;`}
                                                >
                                                    {label}
                                                </option>
                                            );
                                        })}
                                    </select>
                                </div>
                            </div>
                            
                            {/* ... Existing Fields ... */}
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label for="atiendeId" class="block text-xs font-medium text-muted-foreground">Atiende</label>
                                    <select id="atiendeId" name="atiendeId" class="mt-1 block w-full rounded-md border-border bg-input p-2 text-sm">
                                        {agents.map((agent) => (
                                            <option value={agent.id} selected={agent.id === ticket.atiendeId}>{`${agent.nombres} ${agent.apellidos}`}</option>
                                        ))}
                                    </select>
                                </div>
                                <div class="pt-4">
                                    <div class="flex items-center gap-2">
                                        <input type="checkbox" id="archivado" name="archivado" class="h-4 w-4 rounded" checked={ticket.archivado} />
                                        <label for="archivado" class="text-sm font-medium">Archivado</label>
                                    </div>
                                </div>
                            </div>

                            {/* ... Afectado Fields ... */}
                            {(ticket.afectado_clave || ticket.afectado_nombre) && (
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border rounded-md bg-muted/20 p-3">
                                    {ticket.afectado_clave && (
                                        <div>
                                            <label for="afectado_clave" class="block text-xs font-medium text-muted-foreground">{afectadoLabel}</label>
                                            <input type="text" id="afectado_clave" name="afectado_clave" value={ticket.afectado_clave} class="mt-1 block w-full rounded-md border-border bg-input p-2 text-sm font-medium" />
                                        </div>
                                    )}
                                    {ticket.afectado_nombre && (
                                        <div>
                                            <label for="afectado_nombre" class="block text-xs font-medium text-muted-foreground">{nombreLabel}</label>
                                            <input type="text" id="afectado_nombre" name="afectado_nombre" value={ticket.afectado_nombre} class="mt-1 block w-full rounded-md border-border bg-input p-2 text-sm font-medium" />
                                        </div>
                                    )}
                                </div>
                            )}

                            <div>
                                <label class="block text-xs font-medium text-muted-foreground">Descripción</label>
                                <textarea name="descripcion" rows="6" class="mt-1 block w-full rounded-md border-border bg-input p-2 text-sm whitespace-pre-wrap">{ticket.descripcion}</textarea>
                            </div>
                        </div>
                    </>
                )}
            </div>

            <div class="flex justify-between items-start gap-4 mb-4 w-full">
                <div class="grow space-y-2">
                    <div
                        id="drop-zone"
                        class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-6 text-center hover:bg-muted/50 transition-colors cursor-pointer relative"
                    >
                        <p class="text-sm text-muted-foreground mb-4">
                            Arrastre sus archivos aquí o haga clic para
                            seleccionar
                        </p>
                        <div id="attachment-area" class="space-y-2 text-left">
                        </div>
                    </div>
                </div>
            </div>

            <div
                id="action-buttons-container"
                class="flex flex-wrap justify-end items-center gap-4"
            >
                <div class="flex gap-2 w-[176px]">
                    <button
                        type="button"
                        id="upload-files-button"
                        class="bg-muted-foreground text-white hover:bg-muted-foreground/80 px-4 py-2 rounded-md text-sm font-semibold grow h-10"
                    >
                        Adjuntar
                    </button>
                    <button
                        type="button"
                        id="google-drive-button"
                        class="bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2 rounded-md flex items-center justify-center h-10 w-10"
                        title="Adjuntar desde Google Drive"
                    >
                        <img
                            src="/Google_Drive_icon.svg"
                            width="24"
                            height="24"
                            alt="Google Drive"
                        />
                    </button>
                </div>

                <button
                    type="submit"
                    id="submit-button"
                    class="bg-primary text-white hover:bg-primary/80 px-8 py-2 rounded-md text-sm font-semibold w-[176px] h-10"
                >
                    Guardar cambios
                </button>
                <button
                    type="button"
                    id="delete-files-button"
                    class="hidden bg-secondary text-white hover:bg-secondary/80 px-8 py-2 rounded-md text-sm font-semibold w-[176px] h-10"
                >
                    Borrar archivos
                </button>
            </div>
            <p
                id="help-text"
                class="text-sm text-secondary w-full text-right mb-8 mt-2"
            >
                * Máximo 5MB cada uno. Formatos permitidos: jpg, png, pdf, docx,
                xlsx
            </p>
        </form>
        <input type="file" id="file-input" multiple class="hidden" />

        <div class="bg-card border border-secondary rounded-lg p-8">
            <div class="mb-6">
                <label
                    for="new-comment"
                    class="block text-sm font-medium text-muted-foreground mb-2"
                    >Añadir comentario</label
                >
                <textarea
                    id="new-comment"
                    name="new-comment"
                    rows="3"
                    class="w-full rounded-md border-border bg-input p-2 text-sm"
                    placeholder="Escribe un comentario..."></textarea>
            </div>
            <ul class="space-y-6">
                {
                    ticketHistory.length > 0 ? (
                        ticketHistory.map((entry, index) => {
                            const hasFiles =
                                entry.archivos &&
                                (entry.archivos as any).newFiles &&
                                (entry.archivos as any).newFiles.length > 0;
                            const fieldChanges =
                                (entry.cambios as any)?.fieldChanges?.filter(
                                    (c: any) =>
                                        [
                                            "prioridad",
                                            "atiendeId",
                                            "estatusId",
                                            "archivado",
                                            "afectado_clave",
                                            "afectado_nombre",
                                            "descripcion",
                                        ].includes(c.field),
                                ) || [];
                            return (
                                <li
                                    class="flex gap-4 border-t border-border pt-4 first:pt-0 first:border-t-0"
                                    data-history-entry={
                                        index === 0 ? "true" : "false"
                                    }
                                >
                                    <div class="grow">
                                        <div class="flex justify-between items-center">
                                            <p class="font-semibold text-sm">
                                                {entry.usuario.nombres}{" "}
                                                {entry.usuario.apellidos}
                                            </p>
                                            <p class="text-sm text-muted-foreground">
                                                {new Date(
                                                    entry.fecha_cambio,
                                                ).toLocaleString("es-MX", {
                                                    dateStyle: "full",
                                                    timeStyle: "short",
                                                })}
                                            </p>
                                        </div>
                                        <div class="flex items-center gap-4 mt-1">
                                            {entry.estatus && (
                                                <span
                                                    style={`background-color: ${statusColors[entry.estatus.nombre] || "#a1a1aa"};`}
                                                    class="px-2 py-1 text-xs font-bold text-white rounded-full border border-transparent dark:border-white/20"
                                                >
                                                    {entry.estatus.nombre}
                                                </span>
                                            )}
                                            {hasFiles && (
                                                <div class="relative">
                                                    <button
                                                        type="button"
                                                        class="attachment-clip"
                                                        aria-expanded="false"
                                                    >
                                                        <svg
                                                            xmlns="http://www.w3.org/2000/svg"
                                                            width="20"
                                                            height="20"
                                                            viewBox="0 0 24 24"
                                                            fill="none"
                                                            stroke="currentColor"
                                                            stroke-width="2"
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                        >
                                                            <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.59a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                                                        </svg>
                                                    </button>
                                                    <div class="attachment-dropdown hidden absolute z-10 bg-card border rounded-md shadow-lg mt-1 py-1 w-72 max-w-[80vw] md:w-96">
                                                        {(
                                                            entry.archivos as any
                                                        ).newFiles.map(
                                                            (key: string) => (
                                                                <a
                                                                    href="#"
                                                                    data-key={
                                                                        key
                                                                    }
                                                                    class="attachment-link block px-4 py-1 text-sm text-card-foreground hover:underline hover:text-[#722f37]"
                                                                >
                                                                    {parseFileName(
                                                                        key,
                                                                    )}
                                                                </a>
                                                            ),
                                                        )}
                                                    </div>
                                                </div>
                                            )}
                                        </div>
                                        {entry.comentario && (
                                            <p class="mt-2 text-sm p-3 bg-muted/50 rounded-md">
                                                {entry.comentario}
                                            </p>
                                        )}
                                        {fieldChanges.length > 0 && (
                                            <div class="mt-2 text-xs p-2 bg-blue-50 border border-blue-200 dark:bg-blue-900/20 dark:border-blue-800 rounded-md">
                                                <p class="font-semibold mb-1">
                                                    Cambios de campos:
                                                </p>
                                                {fieldChanges.map(
                                                    (change: any) => (
                                                        <p>
                                                            {`• `}
                                                            <span class="font-semibold capitalize">
                                                                {fieldMap[
                                                                    change.field
                                                                ] ||
                                                                    change.field}
                                                                :
                                                            </span>
                                                            {` '${String(change.oldValue)}' → '${String(change.newValue)}'`}
                                                        </p>
                                                    ),
                                                )}
                                            </div>
                                        )}
                                    </div>
                                </li>
                            );
                        })
                    ) : (
                        <p class="text-center text-muted-foreground">
                            No hay historial de cambios para este ticket.
                        </p>
                    )
                }
            </ul>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div
        id="delete-confirmation-modal"
        class="fixed inset-0 z-50 items-center justify-center hidden"
        role="dialog"
        aria-modal="true"
    >
        <div
            class="absolute inset-0 bg-black/50 backdrop-blur-sm"
            id="delete-modal-overlay"
        >
        </div>
        <div
            class="relative bg-card border border-border rounded-lg shadow-lg p-6 w-full max-w-sm mx-4"
        >
            <h3 class="text-lg font-semibold mb-2">Elige el tipo de borrado</h3>
            <p class="text-sm text-muted-foreground mb-6">
                ¿Deseas eliminar todos los archivos adjuntos o seleccionar
                cuáles borrar?
            </p>
            <div class="flex flex-col gap-3">
                <button
                    id="confirm-delete-all"
                    class="w-full bg-destructive text-destructive-foreground hover:bg-destructive/90 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
                >
                    Borrar todos
                </button>
                <button
                    id="confirm-delete-select"
                    class="w-full bg-secondary text-secondary-foreground hover:bg-secondary/80 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
                >
                    Seleccionar
                </button>
                <button
                    id="cancel-delete-modal"
                    class="w-full bg-muted text-muted-foreground hover:bg-muted/80 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
                >
                    Cancelar
                </button>
            </div>
        </div>
    </div>

    <!-- Status Change Confirmation Modal -->
    <div
        id="status-change-confirmation-modal"
        class="fixed inset-0 z-50 items-center justify-center hidden"
        role="dialog"
        aria-modal="true"
    >
        <div
            class="absolute inset-0 bg-black/50 backdrop-blur-sm"
            id="status-change-modal-overlay"
        >
        </div>
        <div
            class="relative bg-card border border-border rounded-lg shadow-lg p-6 w-full max-w-sm mx-4"
        >
            <h3 class="text-lg font-semibold mb-2">Confirmación de Estatus</h3>
            <p class="text-sm text-muted-foreground mb-6">
                ¿Desea cambiar el estatus del ticket a "En espera"?
            </p>
            <div class="flex gap-3">
                <button
                    id="confirm-status-change-yes"
                    class="flex-1 bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
                >
                    Sí
                </button>
                <button
                    id="confirm-status-change-no"
                    class="flex-1 bg-secondary text-secondary-foreground hover:bg-secondary/80 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
                >
                    No
                </button>
            </div>
        </div>
    </div>
</MainLayout>
<script
    define:vars={{
        ticketId,
        ticket,
        statuses,
        currentUserId: session?.user?.id,
        accessToken: session?.accessToken,
    }}
>
    window.ticketViewData = {
        ticketId,
        ticket,
        statuses,
        accessToken: accessToken || "",
        currentUserId: currentUserId ? parseInt(currentUserId, 10) : null,
        isCreator: currentUserId
            ? parseInt(currentUserId, 10) === ticket.solicitanteId
            : false,
    };
</script>
<script>
    import {
        init,
        initEditForm,
        initFileUploads,
        initHistoryToggles,
        initStatusColorizer,
        handleNewHistoryEntry,
    } from "@/scripts/ticket-view-logic.ts";

    document.addEventListener("astro:page-load", () => {
        init();
        initEditForm();
        initFileUploads();
        initHistoryToggles();
        initStatusColorizer();
        handleNewHistoryEntry();
    });
</script>
