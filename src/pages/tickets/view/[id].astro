<script>
    import {
        init,
        initEditForm,
        initFileUploads,
        initHistoryToggles,
        initStatusColorizer,
        handleNewHistoryEntry,
    } from "@/scripts/ticket-view-logic.ts";
    import { toast } from "@/lib/toast";

    document.addEventListener("astro:page-load", () => {
        init();
        initEditForm();
        initFileUploads();
        initHistoryToggles();
        initStatusColorizer();
        handleNewHistoryEntry();



        // --- TRASLADOS EDIT LOGIC ---
        const initTransferLogic = () => {
             const transferForm = document.getElementById("edit-ticket-form");
            if (transferForm) {
                // Parse Options
                const campusOptions = JSON.parse(transferForm.dataset.campusOptions || "[]");
                const carreraOptions = JSON.parse(transferForm.dataset.carreraOptions || "[]");
                const bloqueOptionsFull = JSON.parse(transferForm.dataset.bloqueOptions || "[]");
                const descuentoOptions = JSON.parse(transferForm.dataset.descuentoOptions || "[]");

                // Autocomplete Helper
                function setupAutocomplete(inputId: string, suggestionsId: string, options: string[]) {
                    const input = document.getElementById(inputId) as HTMLInputElement | null;
                    const suggestions = document.getElementById(suggestionsId);
                    if (!input || !suggestions) return;

                    const normalizeText = (text: string) => text.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

                    const closeSuggestions = () => {
                        suggestions.classList.add("hidden");
                        suggestions.innerHTML = "";
                    };

                    input.addEventListener("input", function () {
                        const val = normalizeText((this as HTMLInputElement).value);
                        suggestions.innerHTML = "";
                        if (!val) {
                            closeSuggestions();
                            return;
                        }
                        const filtered = options.filter(opt => normalizeText(opt).includes(val));
                        if (filtered.length > 0) {
                            suggestions.classList.remove("hidden");
                            filtered.forEach(opt => {
                                const div = document.createElement("div");
                                div.textContent = opt;
                                div.className = "p-2 hover:bg-secondary hover:text-secondary-foreground cursor-pointer text-sm transition-colors";
                                div.onclick = () => {
                                    input.value = opt;
                                    closeSuggestions();
                                    if (inputId === 'carrera') handleBloqueOptions();
                                };
                                suggestions.appendChild(div);
                            });
                        } else {
                            closeSuggestions();
                        }
                    });
                    
                    document.addEventListener("click", (e) => {
                        if (e.target !== input && e.target !== suggestions) closeSuggestions();
                    });
                }

                // Bloque Options Logic
                const carreraInput = document.getElementById("carrera") as HTMLInputElement | null;
                const bloqueSelect = document.getElementById("bloque-sugerido") as HTMLSelectElement | null;
                
                const handleBloqueOptions = () => {
                    if (!carreraInput || !bloqueSelect) return;
                    const carreraVal = carreraInput.value.toLowerCase();
                    const normalize = (str: string) => str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                    const carreraNorm = normalize(carreraVal);

                    let filteredOptions: string[] = [];
                    if (carreraNorm.includes("licenciatura")) {
                        const nums = Array.from({length: 16}, (_, i) => String(i + 1));
                        filteredOptions = [...nums, "Actualización"];
                    } else if (carreraNorm.includes("maestria")) {
                        const nums = Array.from({length: 5}, (_, i) => String(i + 1));
                        filteredOptions = [...nums, "Seminario", "Actualización"];
                    } else {
                        filteredOptions = bloqueOptionsFull;
                    }

                    const currentVal = bloqueSelect.dataset.currentVal 
                                        ? bloqueSelect.dataset.currentVal.toLowerCase().replace(/\s+/g, '-') 
                                        : bloqueSelect.value;
                    
                    bloqueSelect.innerHTML = "";
                    filteredOptions.forEach(opt => {
                        const normalizedOpt = opt.toLowerCase().replace(/\s+/g, '-');
                        const optionEl = document.createElement('option');
                        optionEl.value = normalizedOpt;
                        optionEl.textContent = opt;
                        if (normalizedOpt === currentVal) {
                            optionEl.selected = true;
                        }
                        bloqueSelect.appendChild(optionEl);
                    });
                     bloqueSelect.addEventListener('change', () => {
                         bloqueSelect.dataset.currentVal = bloqueSelect.value;
                     });
                };
                
                if(carreraInput) {
                    carreraInput.addEventListener('input', handleBloqueOptions);
                    carreraInput.addEventListener('blur', handleBloqueOptions);
                }

                // Discount Logic
                const tieneDescuentoCk = document.getElementById("tiene_descuento") as HTMLInputElement | null;
                const descuentoContainer = document.getElementById("descuento-container");
                if (tieneDescuentoCk && descuentoContainer) {
                    tieneDescuentoCk.addEventListener("change", () => {
                        if (tieneDescuentoCk.checked) {
                            descuentoContainer.classList.remove("hidden");
                        } else {
                            descuentoContainer.classList.add("hidden");
                            const descValInput = document.getElementById("descuento-valor") as HTMLInputElement | null;
                            if (descValInput) descValInput.value = "";
                        }
                    });
                }

                // Init
                setupAutocomplete("campus-origen", "campus-origen-suggestions", campusOptions);
                setupAutocomplete("campus-destino", "campus-destino-suggestions", campusOptions);
                setupAutocomplete("carrera", "carrera-suggestions", carreraOptions);
                setupAutocomplete("descuento-valor", "descuento-suggestions", descuentoOptions);
                
                handleBloqueOptions();

                // Save
                const saveBtn = document.getElementById("btn-save-transfer-changes");
                if (saveBtn) {
                     // Remove old listener if any (not easily possible without ref, but okay for page load)
                     const newSaveBtn = saveBtn.cloneNode(true) as HTMLButtonElement;
                     saveBtn.replaceWith(newSaveBtn);
                     
                     newSaveBtn.addEventListener("click", async () => {
                         const originalText = newSaveBtn.textContent || "Guardar cambios";
                         newSaveBtn.textContent = "Guardando...";
                         newSaveBtn.disabled = true;

                         const payload = {
                             ticketId: (window as any).ticketViewData.ticketId,
                             prioridad: (document.getElementById("prioridad") as HTMLSelectElement)?.value,
                             estatusId: (document.getElementById("estatusId") as HTMLSelectElement)?.value,
                             atiendeId: (document.querySelector("select[name='atiendeId']") as HTMLSelectElement)?.value,
                             
                             matricula: (document.getElementById("matricula") as HTMLInputElement)?.value,
                             alumno: (document.getElementById("alumno") as HTMLInputElement)?.value,
                             campusOrigen: (document.getElementById("campus-origen") as HTMLInputElement)?.value,
                             campusDestino: (document.getElementById("campus-destino") as HTMLInputElement)?.value,
                             carrera: (document.getElementById("carrera") as HTMLInputElement)?.value,
                             nuevo_ingreso: (document.getElementById("nuevo_ingreso") as HTMLInputElement)?.checked,
                             tiene_descuento: (document.getElementById("tiene_descuento") as HTMLInputElement)?.checked,
                             descuento_nombre: (document.getElementById("descuento-valor") as HTMLInputElement)?.value,
                             bloque_nombre: (document.getElementById("bloque-sugerido") as HTMLSelectElement)?.value,
                             
                             auditor_docsId: (document.querySelector("select[name='auditor_docsId']") as HTMLSelectElement)?.value,
                             auditor_reqId: (document.querySelector("select[name='auditor_reqId']") as HTMLSelectElement)?.value,
                             validacion_docs: (document.querySelector("input[name='validacion_docs']") as HTMLInputElement)?.checked,
                             descripcion_docs: (document.querySelector("textarea[name='descripcion_docs']") as HTMLTextAreaElement)?.value,
                             validacion_edocta: (document.querySelector("input[name='validacion_edocta']") as HTMLInputElement)?.checked,
                             descripcion_edocta: (document.querySelector("textarea[name='descripcion_edocta']") as HTMLTextAreaElement)?.value,
                             validacion_calif: (document.querySelector("input[name='validacion_calif']") as HTMLInputElement)?.checked,
                             descripcion_calif: (document.querySelector("textarea[name='descripcion_calif']") as HTMLTextAreaElement)?.value
                         };

                         try {
                             const res = await fetch("/api/tickets/update", {
                                 method: "PATCH",
                                 headers: { "Content-Type": "application/json" },
                                 body: JSON.stringify(payload)
                             });
                             if (!res.ok) throw new Error("Error updating ticket");
                             toast.success("Ticket actualizado correctamente");
                             setTimeout(() => window.location.reload(), 1000);
                         } catch (e) {
                             console.error(e);
                             toast.error("Error al actualizar");
                             newSaveBtn.textContent = originalText;
                             newSaveBtn.disabled = false;
                         }
                     });
                }
            }
        };
        initTransferLogic();
    });

</script>
