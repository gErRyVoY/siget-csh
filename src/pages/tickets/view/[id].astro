---
import MainLayout from "@/layouts/MainLayout.astro";
import { getSession } from "auth-astro/server";
import { prisma } from "@/lib/db";
import {
    type Ticket,
    type Estatus,
    type Usuario,
    Prioridad,
    type HistorialSolicitud,
    type Subcategoria,
} from "@prisma/client";
import {
    campusOptions,
    carreraOptions,
    bloqueOptions,
} from "@/config/form-options";

// Fetch options for autocomplete with IDs
const allCampuses = await prisma.empresa.findMany({
    where: { activa: true },
    select: { id: true, nombre: true }
});
const allCarreras = await prisma.carrera.findMany({
    where: { activo: true },
    include: { oferta: true }
});
const mappedCarreras = allCarreras.map(c => {
     let label = c.descripcion;
     if (c.oferta.descripcion.includes("Licenciatura")) label = `Licenciatura en ${label}`;
     else if (c.oferta.descripcion.includes("Maestría")) label = `Maestría en ${label}`;
     else if (c.oferta.descripcion.includes("Doctorado")) label = `Doctorado en ${label}`;
     return { id: c.id, label };
});
const allDescuentos = await prisma.descuento.findMany({
    where: { activo: true },
    select: { id: true, descripcion: true }
});

const mappedCampuses = allCampuses.map(c => ({ id: c.id, label: c.nombre }));
const mappedDescuentos = allDescuentos.map(d => ({ id: d.id, label: d.descripcion }));

const { id } = Astro.params;
if (!id) {
    return Astro.redirect("/404");
}

const ticketId = parseInt(id, 10);

const S3_BUCKET_URL = `https://${import.meta.env.S3_BUCKET_NAME}.s3.${import.meta.env.S3_REGION}.amazonaws.com`;

// Google Drive credentials — usar process.env para leer en RUNTIME.
// IMPORTANTE: import.meta.env es reemplazado estáticamente por Vite en build-time.
// Si las variables no existen durante el build (Docker), quedan como string vacío.
// process.env sí lee del entorno real del proceso Node.js en producción.
const GOOGLE_API_KEY_SERVER = process.env.GOOGLE_API_KEY || '';
const GOOGLE_CLIENT_ID_SERVER = process.env.GOOGLE_CLIENT_ID || '';
const GOOGLE_APP_ID_SERVER = process.env.GOOGLE_APP_ID || '';

const ALLOWED_STATUSES = [
    "Nuevo",
    "En progreso",
    "En espera",
    "Solucionado",
    "Cancelado",
    "Duplicado",
];
const statusColors: { [key: string]: string } = {
    Nuevo: "#a1a1aa",
    "En progreso": "#3b82f6",
    "En espera": "#38bdf8",
    Solucionado: "#84cc16",
    Cancelado: "#dc2626",
    Duplicado: "#171717",
};

// Consultas secuenciales para evitar el agotamiento del connection pool
const ticket = await prisma.ticket.findUnique({
    where: { id: ticketId },
    include: {
        estatus: true,
        categoria: true,
        subcategoria: true,
        solicitante: { include: { empresa: true } },
        atiende: true,
        empresa: true,
        traslados: {
            include: {
                origen: true,
                destino: true,
                carrera: {
                    include: {
                        oferta: true,
                    }
                },
                descuento: true,
                bloque: true,
            },
        },
    },
});
const ticketHistory = await prisma.historialSolicitud.findMany({
    where: { ticketId: ticketId },
    include: {
        usuario: { select: { nombres: true, apellidos: true } },
        estatus: { select: { nombre: true } },
    },
    orderBy: { fecha_cambio: "desc" },
});
// Agentes de soporte CSH (roles: S-1, S-2, S-3, Dev, Coord, Director)
const cshSupportUsers = await prisma.usuario.findMany({
    where: {
        empresaId: 15,
        activo: true,
        rolId: { in: [1, 2, 3, 4, 8, 9] },
    },
});
const cshAuditorDocs = await prisma.usuario.findMany({
    where: { empresaId: 15, activo: true, auditor_docs: true },
});
const cshAuditorReq = await prisma.usuario.findMany({
    where: { empresaId: 15, activo: true, auditor_req: true },
});

if (!ticket) {
    return Astro.redirect("/404");
}

const session = await getSession(Astro.request);
const PRIVILEGED_ROLES = [1, 2, 3, 4, 5, 6, 15];
const isPrivileged = session?.user
    ? PRIVILEGED_ROLES.includes(session.user.rol?.id ?? -1)
    : false;
const isReadOnly = false; // Reverted: Allow editing for all statuses



const breadcrumbPath = [ticket.categoria.nombre];
if (ticket.subcategoria) {
    let currentSub: Subcategoria | null = ticket.subcategoria;
    const subPath = [];
    while (currentSub) {
        subPath.unshift(currentSub.nombre);
        if (currentSub.parent_subcategoriaId) {
            currentSub = await prisma.subcategoria.findUnique({
                where: { id: currentSub.parent_subcategoriaId },
            });
        } else {
            currentSub = null;
        }
    }
    breadcrumbPath.push(...subPath);
}

let statuses: Estatus[] = [];
let agents: Usuario[] = [];
const priorities = Object.values(Prioridad);

// Fetch statuses for everyone
statuses = await prisma.estatus.findMany({
    where: { nombre: { in: ALLOWED_STATUSES } },
});

const MARKETING_CATEGORY_ID = 12;

if (isPrivileged) {
    // Privileged users see all agents
    if (ticket.categoriaId === MARKETING_CATEGORY_ID) {
        agents = await prisma.usuario.findMany({
            where: {
                empresa: { nombre: "Corporativo" },
                rol: { rol: { in: ['Community manager', 'Director Marketing', 'Diseñador', 'Editor'] } },
                activo: true
            },
            orderBy: { nombres: "asc" }
        });
    } else {
        agents = await prisma.usuario.findMany({
            where: { rolId: { in: PRIVILEGED_ROLES }, activo: true },
        });
    }
} else {
    // Regular users only see the current agent (if any)
    if (ticket.atiende) {
        agents = [ticket.atiende];
    }

    // Regular users cannot select 'Nuevo' if it's not currently 'Nuevo'
    if (ticket.estatus.nombre !== "Nuevo") {
        statuses = statuses.filter((s) => s.nombre !== "Nuevo");
    }
}

const parseFileName = (key: string) => {
    if (!key) return "archivo-desconocido";
    return key.split("/").pop()?.split("-").slice(1).join("-") || key;
};

const source = Astro.url.searchParams.get("source");
const backLink =
    source === "mis-tickets" ? "/tickets/soporte/usuario" : "/tickets/soporte";

let afectadoLabel = "Clave";
let nombreLabel = "Nombre del Afectado";

if (ticket.categoriaId === 1) {
    afectadoLabel = "Matrícula";
    nombreLabel = "Nombre del Alumno";
} else if (ticket.categoriaId === 2) {
    afectadoLabel = "Folio";
    nombreLabel = "Nombre del Aspirante";
} else if (ticket.categoriaId === 3) {
    nombreLabel = "Nombre del Colaborador";
} else if (ticket.categoriaId === 4) {
    nombreLabel = "Nombre del Docente";
}

const fieldMap: Record<string, string> = {
    prioridad: "Prioridad",
    estatusId: "Estatus",
    atiendeId: "Atiende",
    archivado: "Archivado",
    afectado_clave: afectadoLabel,
    afectado_nombre: nombreLabel,
    descripcion: "Descripción",
    // Traslados keys
    matricula: "Matrícula",
    alumno: "Nombre Alumno",
    nuevo_ingreso: "Nuevo Ingreso",
    bloque_nombre: "Bloque",
    origen_nombre: "Campus Origen",
    destino_nombre: "Campus Destino",
    carrera_nombre: "Carrera",
    descuento_nombre: "Descuento",
    validacion_docs: "Validación Documentos",
    descripcion_docs: "Comentarios Documentos",
    validacion_edocta: "Validación Adeudo Financiero",
    descripcion_edocta: "Comentarios Edo. Cta.",
    validacion_calif: "Validación Adeudo Escolar",
    descripcion_calif: "Comentarios Académicos",
    auditor_docs: "Auditor Documentos",
    auditor_req: "Auditor Requisitos/Adeudos",
};

const isTraslado = ticket.traslados && ticket.traslados.length > 0;
const traslado = isTraslado ? ticket.traslados[0] : null;

const currentUserId = session?.user?.id ? parseInt(String(session.user.id), 10) : -1;
const isOwner = ticket.solicitanteId === currentUserId;

// Permission Logic for Auditors
const canEditDocs = isPrivileged || (traslado && traslado.auditor_docsId === currentUserId);
const canEditReq = isPrivileged || (traslado && traslado.auditor_reqId === currentUserId);

const ofertaDesc = traslado?.carrera?.oferta?.descripcion || "";
let carreraDisplayValue = traslado?.carrera?.descripcion || "";
if (ofertaDesc.includes("Licenciatura")) carreraDisplayValue = `Licenciatura en ${carreraDisplayValue}`;
else if (ofertaDesc.includes("Maestría")) carreraDisplayValue = `Maestría en ${carreraDisplayValue}`;
else if (ofertaDesc.includes("Doctorado")) carreraDisplayValue = `Doctorado en ${carreraDisplayValue}`;

console.log("CAREER DEBUG:", { ofertaDesc, carreraOriginal: traslado?.carrera?.descripcion, carreraFinal: carreraDisplayValue });
---

<MainLayout title={`Ticket #${isTraslado ? "TRL-" : ""}${ticket.id}`}>
    <style>
        @keyframes flash {
            0% {
                background-color: transparent;
            }
            50% {
                background-color: var(--muted);
            }
            100% {
                background-color: transparent;
            }
        }
        .flash-animation {
            animation: flash 1s ease-in-out;
        }
        @media (max-width: 1119px) {
            #action-buttons-container.has-files {
                flex-direction: column;
                align-items: end;
                width: calc(2 / 5 * 100%);
            }
            #action-buttons-container.has-files #submit-button {
                order: 1;
            }
            #action-buttons-container.has-files #upload-files-button {
                order: 2;
            }
            #action-buttons-container.has-files #delete-files-button {
                order: 3;
            }
            #action-buttons-container.has-files #help-text {
                order: 4;
                text-align: right;
            }
        }
    </style>
    <div class="max-w-4xl mx-auto">
        <div class="mb-4 text-sm text-muted-foreground">
            {breadcrumbPath.join(" > ")}
        </div>

        <form 
            id="edit-ticket-form"
            data-campus-list={JSON.stringify(mappedCampuses)}
            data-carrera-list={JSON.stringify(mappedCarreras)}
            data-descuento-list={JSON.stringify(mappedDescuentos)}
            data-bloque-options={JSON.stringify(bloqueOptions)}
            data-api-key={GOOGLE_API_KEY_SERVER}
            data-client-id={GOOGLE_CLIENT_ID_SERVER}
            data-app-id={GOOGLE_APP_ID_SERVER}
        >
            <div class="bg-card border border-secondary rounded-lg p-4 mb-4">
                {isTraslado && traslado ? (
                    /* --- VISTA TRASLADOS (EDITABLE) --- */
                    <div class="space-y-6">
                        {/* Hidden Inputs for IDs */}
                        <input type="hidden" name="origenId" id="origenId" value={traslado.origenId ?? ''} />
                        <input type="hidden" name="destinoId" id="destinoId" value={traslado.destinoId ?? ''} />
                        <input type="hidden" name="carreraId" id="carreraId" value={traslado.carreraId ?? ''} />
                        <input type="hidden" name="descuentoId" id="descuentoId" value={traslado.descuentoId ?? ''} />
                        {/* Header: Back Button & Status & Save */}
                        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                            <div class="flex justify-end items-center lg:justify-start gap-4 w-full">
                                <a
                                    href={backLink}
                                    class="bg-muted-foreground text-white hover:bg-muted-foreground/90 px-6 py-2 rounded-md text-sm font-semibold transition-colors shrink-0"
                                >
                                    Volver a la lista
                                </a>
                                {/* Only show Save button if privileged or owner (handled by logic usually, but here checking privilege for layout) */}
                                {(isPrivileged || isOwner) && (
                                    <button
                                        type="button"
                                        id="btn-save-transfer-changes"
                                        class="bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-2 rounded-md text-sm font-semibold shadow transition-colors"
                                    >
                                        Guardar cambios
                                    </button>
                                )}
                            </div>
                            
                            <div class="flex items-center gap-4 w-full justify-end">
                                <div>
                                    <label for="prioridad" class="block text-xs font-medium text-muted-foreground text-right mb-1">Prioridad</label>
                                    <select
                                        id="prioridad"
                                        name="prioridad"
                                        class="block w-32 rounded-md border-border bg-input p-2 text-sm"
                                        disabled={!isPrivileged && !isOwner}
                                    >
                                        {priorities.map((p) => (
                                            <option value={p} selected={p === ticket.prioridad}>{p}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label for="estatusId" class="block text-xs font-medium text-muted-foreground text-right mb-1">Estatus</label>
                                    <select
                                        id="estatusId"
                                        name="estatusId"
                                        class="block w-40 rounded-md border-border p-2 text-sm font-medium"
                                        style={`background-color: ${(ticket.estatus.nombre === "Nuevo" && !ticket.atiendeId) ? "var(--primary)" : (statusColors[ticket.estatus.nombre] || "#a1a1aa")}; color: white;`}
                                        disabled={!isPrivileged && !isOwner}
                                    >
                                        {statuses.map((s) => {
                                            let label = s.nombre;
                                            let color = statusColors[s.nombre] || "#a1a1aa";
                                            if (s.nombre === "Nuevo" && !ticket.atiendeId) {
                                                label = "Sin asignar";
                                                color = "var(--primary)";
                                            }
                                            return (
                                                <option 
                                                    value={s.id} 
                                                    selected={s.id === ticket.estatusId} 
                                                    style={`background-color: ${color}; color: white;`}
                                                >
                                                    {label}
                                                </option>
                                            );
                                        })}
                                    </select>
                                </div>
                            </div>
                        </div>

                         <div id="transfer-edit-fields" class="space-y-6">
                            {/* Student Info */}
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-b border-border pb-6">
                                <div>
                                    <label for="matricula" class="block text-xs font-medium text-muted-foreground mb-1">Matrícula</label>
                                    <input 
                                        type="text" 
                                        id="matricula" 
                                        name="matricula" 
                                        value={traslado.matricula} 
                                        class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                        disabled={!isPrivileged && !isOwner}
                                    />
                                </div>
                                <div>
                                    <label for="alumno" class="block text-xs font-medium text-muted-foreground mb-1">Nombre del alumno</label>
                                    <input 
                                        type="text" 
                                        id="alumno" 
                                        name="alumno" 
                                        value={traslado.alumno} 
                                        class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                        disabled={!isPrivileged && !isOwner}
                                    />
                                </div>
                            </div>

                            {/* Campus Info */}
                             <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-b border-border pb-6">
                                <div class="relative">
                                    <label for="campus-origen" class="block text-xs font-medium text-muted-foreground mb-1">Campus origen</label>
                                    <input type="hidden" id="origenId" name="origenId" value={traslado.origenId || ''} />
                                    <input 
                                        type="text" 
                                        id="campus-origen" 
                                        name="campus-origen" 
                                        value={traslado.origen?.nombre} 
                                        class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                        autocomplete="off"
                                        disabled={!isPrivileged && !isOwner}
                                    />
                                    <div id="campus-origen-suggestions" class="absolute z-10 w-full bg-popover text-popover-foreground border border-[#797979] rounded-md mt-1 hidden max-h-40 overflow-y-auto shadow-md"></div>
                                </div>
                                <div class="relative">
                                    <label for="campus-destino" class="block text-xs font-medium text-muted-foreground mb-1">Campus destino</label>
                                    <input type="hidden" id="destinoId" name="destinoId" value={traslado.destinoId || ''} />
                                    <input 
                                        type="text" 
                                        id="campus-destino" 
                                        name="campus-destino" 
                                        value={traslado.destino?.nombre} 
                                        class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                        autocomplete="off"
                                        disabled={!isPrivileged && !isOwner}
                                    />
                                    <div id="campus-destino-suggestions" class="absolute z-10 w-full bg-popover text-popover-foreground border border-[#797979] rounded-md mt-1 hidden max-h-40 overflow-y-auto shadow-md"></div>
                                </div>
                            </div>

                            {/* Career */}
                            <div class="border-b border-border pb-6 relative">
                                <label for="carrera" class="block text-xs font-medium text-muted-foreground mb-1">Carrera</label>
                                <input type="hidden" id="carreraId" name="carreraId" value={traslado.carreraId || ''} />
                                <input 
                                    type="text" 
                                    id="carrera" 
                                    name="carrera" 
                                    value={carreraDisplayValue} 
                                    class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                    autocomplete="off"
                                    disabled={!isPrivileged && !isOwner}
                                />
                                <div id="carrera-suggestions" class="absolute z-10 w-full bg-popover text-popover-foreground border border-[#797979] rounded-md mt-1 hidden max-h-48 overflow-y-auto shadow-md"></div>
                            </div>

                            {/* Admission, Discount & Block */}
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 border-b border-border pb-6 items-start">
                                <div>
                                    <div class="flex items-center gap-2 mb-2 h-5">
                                        <input 
                                            type="checkbox" 
                                            id="nuevo_ingreso" 
                                            name="nuevo_ingreso" 
                                            checked={traslado.nuevo_ingreso} 
                                            class="rounded border-input text-primary focus:ring-primary"
                                            disabled={!isPrivileged && !isOwner}
                                        />
                                        <label for="nuevo_ingreso" class="text-xs font-medium text-muted-foreground">¿Es nuevo ingreso?</label>
                                    </div>
                                </div>
                                
                                <div>
                                    <div class="flex items-center gap-2 mb-2 h-5">
                                        <input 
                                            type="checkbox" 
                                            id="tiene_descuento" 
                                            name="tiene_descuento" 
                                            checked={!!traslado.descuento} 
                                            class="rounded border-input text-primary focus:ring-primary"
                                            disabled={!isPrivileged && !isOwner}
                                        />
                                        <label for="tiene_descuento" class="text-xs font-medium text-muted-foreground">¿Tiene descuento?</label>
                                    </div>
                                    <div id="descuento-container" class={`relative ${!!traslado.descuento ? '' : 'hidden'}`}>
                                        <input type="hidden" id="descuentoId" name="descuentoId" value={traslado.descuentoId || ''} />
                                        <input 
                                            type="text" 
                                            id="descuento-valor" 
                                            name="descuento-valor"
                                            value={traslado.descuento?.descripcion || ''}
                                            class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                            placeholder="Buscar descuento..."
                                            autocomplete="off"
                                            disabled={!isPrivileged && !isOwner}
                                        />
                                        <div id="descuento-suggestions" class="absolute z-10 w-full bg-popover text-popover-foreground border border-[#797979] rounded-md mt-1 hidden max-h-40 overflow-y-auto shadow-md"></div>
                                    </div>
                                </div>

                                <div>
                                    <label for="bloque-sugerido" class="block text-xs font-medium text-muted-foreground mb-2 h-5">Bloque sugerido</label>
                                    <select 
                                        id="bloque-sugerido" 
                                        name="bloque_nombre" 
                                        class="w-full rounded-md border-border bg-input px-3 py-2 text-sm"
                                        disabled={!isPrivileged && !isOwner}
                                        data-current-val={traslado.bloque_nombre || traslado.bloque?.descripcion}
                                    >
                                        {/* Options populated by JS */}
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        {/* Initial Comment & Attachments (Read Only Section) */}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-b border-border pb-6">
                             <div>
                                <label class="block text-xs font-medium text-muted-foreground mb-1">Comentario Inicial</label>
                                <div class="p-3 bg-muted/20 rounded-md border border-border text-sm min-h-[80px] whitespace-pre-wrap">
                                    {ticket.descripcion || "Sin comentarios."}
                                </div>
                             </div>
                             <div>
                                <label class="block text-xs font-medium text-muted-foreground mb-1">Archivos adjuntos</label>
                                {(ticket.archivos as any[]) && (ticket.archivos as any[]).length > 0 ? (
                                    <div class="flex items-center flex-wrap gap-2 text-sm p-2 rounded-md border border-border bg-card">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="text-muted-foreground"
                                        >
                                            <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.59a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                                        </svg>
                                        {(ticket.archivos as any[]).map((file: any, index: number) => {
                                            const key = typeof file === 'string' ? file : (file.key || file.url);
                                            const name = typeof file === 'string' ? parseFileName(key) : (file.nombre || parseFileName(key));
                                            return (
                                                <>
                                                    <a 
                                                        href={`/api/tickets/attachment?key=${encodeURIComponent(key)}`}
                                                        target="_blank" 
                                                        rel="noopener noreferrer"
                                                        class="text-primary hover:underline hover:text-primary/80 transition-colors"
                                                    >
                                                        {name}
                                                    </a>
                                                    {index < (ticket.archivos as any[]).length - 1 && <span class="text-muted-foreground">, </span>}
                                                </>
                                            );
                                        })}
                                    </div>
                                ) : (
                                    <p class="text-sm text-muted-foreground italic p-2">No hay archivos adjuntos.</p>
                                )}
                             </div>
                        </div>

                        {/* 3-Column Assignment Section (Existing Logic kept as is, just wrapped) */}
                        <div class="grid grid-cols-1 custom-lg:grid-cols-3 gap-4">
                            <style>
                                @media (min-width: 1100px) {
                                    .custom-lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
                                }
                            </style>
                            
                            {/* Col 1: Atiende */}
                            <div class="space-y-2 bg-muted/10 p-3 rounded-md border border-border/50">
                                <h4 class="font-semibold text-sm border-b border-border pb-2 mb-2">Atiende</h4>
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-muted-foreground">Ingeniero asignado:</span>
                                    {isPrivileged ? (
                                        <select 
                                            id="atiendeId"
                                            name="atiendeId" 
                                            class="w-full rounded-md border-border bg-input p-1 text-sm"
                                        >
                                            <option value="">Sin asignar</option>
