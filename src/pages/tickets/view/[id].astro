    define:vars={{
        ticketId,
        ticket,
        statuses,
        currentUserId: session?.user?.id,
        accessToken: session?.accessToken,
    }}
>
    window.ticketViewData = {
        ticketId,
        ticket,
        statuses,
        accessToken: accessToken || "",
        currentUserId: currentUserId ? parseInt(currentUserId, 10) : null,
        isCreator: currentUserId
            ? parseInt(currentUserId, 10) === ticket.solicitanteId
            : false,
