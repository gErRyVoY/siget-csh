<MainLayout title="Gestión de categorías">
    <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex justify-between items-center">
            <button
                type="button"
                id="reset-filters-button"
                class="bg-muted-foreground text-white hover:bg-muted-foreground/80 px-4 py-2 rounded-md text-sm font-semibold h-10"
            >
                Restablecer
            </button>
        </div>

        <div class="bg-card border border-border rounded-lg overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead
                        class="bg-muted text-muted-foreground uppercase text-xs"
                    >
                        <tr>
                            <th class="p-3 relative">
                                <div class="flex items-center justify-between gap-2">
                                    <span>Categoría</span>
                                    <button
                                        class="filter-dropdown-trigger hover:bg-muted-foreground/20 p-1 rounded"
                                        data-column="categoria"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-4 w-4"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </button>
                                </div>
                                <!-- Dropdown -->
                                <div
                                    class="filter-dropdown hidden absolute top-full left-0 mt-1 bg-card border border-border rounded-md shadow-lg z-50 min-w-[200px] max-h-64 overflow-y-auto"
                                    data-column="categoria"
                                >
                                    <div class="p-2 space-y-1">
                                        {
                                            uniqueCategorias.map((cat) => (
                                                <label class="flex items-center gap-2 text-sm hover:bg-muted/50 p-1 rounded cursor-pointer categoria-option">
                                                    <input
                                                        type="checkbox"
                                                        class="filter-checkbox"
                                                        data-column="categoria"
                                                        data-value={cat}
                                                        checked
                                                    />
                                                    <span class="normal-case">
                                                        {cat}
                                                    </span>
                                                </label>
                                            ))
                                        }
                                    </div>
                                </div>
                            </th>
                            {
                                Array.from({ length: maxLevelUsed }).map(
                                    (_, i) => (
                                        <th class="p-3 relative">
                                            <div class="flex items-center justify-between gap-2">
                                                <span>
                                                    Subcategoría {i + 1}
                                                </span>
                                                <button
                                                    class="filter-dropdown-trigger hover:bg-muted-foreground/20 p-1 rounded"
                                                    data-column={`nivel${i}`}
                                                >
                                                    <svg
                                                        xmlns="http://www.w3.org/2000/svg"
                                                        class="h-4 w-4"
                                                        viewBox="0 0 20 20"
                                                        fill="currentColor"
                                                    >
                                                        <path
                                                            fill-rule="evenodd"
                                                            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                                            clip-rule="evenodd"
                                                        />
                                                    </svg>
                                                </button>
                                            </div>
                                            <!-- Dropdown -->
                                            <div
                                                class="filter-dropdown hidden absolute top-full left-0 mt-1 bg-card border border-border rounded-md shadow-lg z-50 min-w-[200px] max-h-64 overflow-y-auto"
                                                data-column={`nivel${i}`}
                                            >
                                                <div
                                                    class="p-2 space-y-1"
                                                    data-nivel-index={i}
                                                >
                                                    <label class="flex items-center gap-2 text-sm hover:bg-muted/50 p-1 rounded cursor-pointer font-semibold">
                                                        <input
                                                            type="checkbox"
                                                            class="filter-all"
                                                            data-column={`nivel${i}`}
                                                            checked
                                                        />
                                                        <span>Todos</span>
                                                    </label>
                                                    {uniqueNiveles[i].map(
                                                        (nivel) => (
                                                            <label class="flex items-center gap-2 text-sm hover:bg-muted/50 p-1 rounded cursor-pointer filter-option">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox"
                                                                    data-column={`nivel${i}`}
                                                                    data-value={
                                                                        nivel
                                                                    }
                                                                    checked
                                                                />
                                                                <span class="normal-case">
                                                                    {nivel}
                                                                </span>
                                                            </label>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        </th>
                                    ),
                                )
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        {
                            displayRows.map((row, rowIdx) => (
                                <tr
                                    class="hover:bg-muted/50 table-row"
                                    data-categoria={row.categoria}
                                    data-show-categoria={row.showCategoria}
                                    data-niveles={JSON.stringify(
                                        row.niveles.slice(0, maxLevelUsed),
                                    )}
                                >
                                    <td
                                        class:list={[
                                            "p-3 font-medium",
                                            !row.showCategoria && "bg-muted/30",
                                        ]}
                                    >
                                        {row.showCategoria
                                            ? row.categoria
                                            : "-"}
                                    </td>
                                    {row.niveles
                                        .slice(0, maxLevelUsed)
                                        .map((nivel, idx) => (
                                            <td
                                                class:list={[
                                                    "p-3 text-muted-foreground",
                                                    (!row.showNiveles[idx] ||
                                                        nivel === "-") &&
                                                        "bg-muted/30",
                                                ]}
                                            >
                                                {row.showNiveles[idx]
                                                    ? nivel
                                                    : "-"}
                                            </td>
                                        ))}
                                </tr>
                            ))
                        }
                        {
                            displayRows.length === 0 && (
                                <tr>
                                    <td
                                        colspan={maxLevelUsed + 1}
                                        class="p-6 text-center text-muted-foreground"
                                    >
                                        No hay categorías registradas.
                                    </td>
                                </tr>
                            )
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</MainLayout>

<script>
    // Cascading filter logic
    function setupFilters() {
        const filterDropdownTriggers = document.querySelectorAll(
            ".filter-dropdown-trigger",
        );
        const filterDropdowns = document.querySelectorAll(".filter-dropdown");
        const tableRows = document.querySelectorAll(".table-row");

        // Toggle dropdown visibility
        filterDropdownTriggers.forEach((trigger) => {
            trigger.addEventListener("click", (e) => {
                e.stopPropagation();
                const column = (trigger as HTMLElement).dataset.column;
                const dropdown = document.querySelector(
                    `.filter-dropdown[data-column="${column}"]`,
                ) as HTMLElement | null;
                
                // Close all other dropdowns
                filterDropdowns.forEach((d) => {
                    if (d !== dropdown) {
                        d.classList.add("hidden");
                        // Reset positioning
                        (d as HTMLElement).style.position = "";
                        (d as HTMLElement).style.top = "";
                        (d as HTMLElement).style.left = "";
                    }
                });
                
                const wasHidden = dropdown?.classList.contains("hidden");
                dropdown?.classList.toggle("hidden");
                
                // If opening dropdown, position it using fixed coordinates
                if (dropdown && !dropdown.classList.contains("hidden")) {
                    // Get the parent th element for proper column alignment
                    const thElement = trigger.closest("th") as HTMLElement;
                    const rect = thElement ? thElement.getBoundingClientRect() : trigger.getBoundingClientRect();
                    dropdown.style.position = "fixed";
                    dropdown.style.top = `${rect.bottom + 4}px`;
                    dropdown.style.left = `${rect.left}px`;
                    dropdown.style.zIndex = "9999";
                }
            });
        });

        // Close dropdowns when clicking outside
        document.addEventListener("click", (e) => {
            if (
                !(e.target as HTMLElement).closest(".filter-dropdown") &&
                !(e.target as HTMLElement).closest(".filter-dropdown-trigger")
            ) {
                filterDropdowns.forEach((d) => {
                    d.classList.add("hidden");
                    // Reset positioning
                    (d as HTMLElement).style.position = "";
                    (d as HTMLElement).style.top = "";
                    (d as HTMLElement).style.left = "";
                });
            }
        });

        // Prevent dropdown from closing when clicking inside
        filterDropdowns.forEach((dropdown) => {
            dropdown.addEventListener("click", (e) => {
                e.stopPropagation();
            });
        });

        // --- CATEGORY checkboxes: options NEVER hidden ---
        const categoriaCheckboxes = document.querySelectorAll(
            '.filter-checkbox[data-column="categoria"]',
        ) as NodeListOf<HTMLInputElement>;

        categoriaCheckboxes.forEach((cb) => {
            cb.addEventListener("change", () => {
                applyFilters();
                updateCascadingOptions();
            });
        });

        // --- SUBCATEGORY "Todos" checkboxes ---
        const filterAllCheckboxes = document.querySelectorAll(
            ".filter-all",
        ) as NodeListOf<HTMLInputElement>;

        filterAllCheckboxes.forEach((allCb) => {
            allCb.addEventListener("change", () => {
                const column = allCb.dataset.column!;
                const checkboxes = document.querySelectorAll(
                    `.filter-checkbox[data-column="${column}"]`,
                ) as NodeListOf<HTMLInputElement>;
                checkboxes.forEach((cb) => {
                    cb.checked = allCb.checked;
                });
                applyFilters();
                updateCascadingOptions();
            });
        });

        // --- SUBCATEGORY individual checkboxes ---
        const nivelCheckboxes = document.querySelectorAll(
            '.filter-checkbox:not([data-column="categoria"])',
        ) as NodeListOf<HTMLInputElement>;

        nivelCheckboxes.forEach((cb) => {
            cb.addEventListener("change", () => {
                const column = cb.dataset.column!;
                updateAllCheckbox(column);
                applyFilters();
                updateCascadingOptions();
            });
        });

        function updateAllCheckbox(column: string) {
            const checkboxes = Array.from(
                document.querySelectorAll(
                    `.filter-checkbox[data-column="${column}"]`,
                ),
            ) as HTMLInputElement[];
            const allCheckbox = document.querySelector(
                `.filter-all[data-column="${column}"]`,
            ) as HTMLInputElement | null;

            if (!allCheckbox) return;

            const allChecked = checkboxes.every((cb) => cb.checked);
            const noneChecked = checkboxes.every((cb) => !cb.checked);

            if (allChecked) {
                allCheckbox.checked = true;
                allCheckbox.indeterminate = false;
            } else if (noneChecked) {
                allCheckbox.checked = false;
                allCheckbox.indeterminate = false;
            } else {
                allCheckbox.indeterminate = true;
            }
        }

        function applyFilters() {
            // Get selected categories
            const selectedCategoria: string[] = [];
            categoriaCheckboxes.forEach((cb) => {
                if (cb.checked && cb.dataset.value) {
                    selectedCategoria.push(cb.dataset.value);
                }
            });

            // Get selected niveles
            const selectedNiveles: string[][] = [];
            let nivelIdx = 0;
            while (
                document.querySelector(
                    `.filter-checkbox[data-column="nivel${nivelIdx}"]`,
                )
            ) {
                const selected: string[] = [];
                document
                    .querySelectorAll(
                        `.filter-checkbox[data-column="nivel${nivelIdx}"]:checked`,
                    )
                    .forEach((cb) => {
                        const val = (cb as HTMLInputElement).dataset.value;
                        if (val) selected.push(val);
                    });
                selectedNiveles.push(selected);
                nivelIdx++;
            }

            // Apply filters to each row
            tableRows.forEach((row) => {
                const el = row as HTMLElement;
                const categoria = el.dataset.categoria!;
                const niveles = JSON.parse(el.dataset.niveles!);

                // Get all td elements in this row
                const cells = el.querySelectorAll("td");
                
                // Check if category is selected
                const categoriaSelected = selectedCategoria.includes(categoria);
                
                // Update category cell (first td)
                if (cells[0]) {
                    if (categoriaSelected) {
                        // Restore original value if it was showing
                        const originalText = cells[0].getAttribute("data-original-text");
                        if (originalText !== null) {
                            cells[0].textContent = originalText;
                        }
                        cells[0].classList.remove("bg-muted/30");
                    } else {
                        // Store original if not already stored
                        if (!cells[0].hasAttribute("data-original-text")) {
                            cells[0].setAttribute("data-original-text", cells[0].textContent || "");
                        }
                        cells[0].textContent = "-";
                        cells[0].classList.add("bg-muted/30");
                    }
                }

                // Track if ALL subcategory levels are filtered (to hide row)
                let allNivelesFiltered = true;

                // Update subcategory cells
                niveles.forEach((nivel: string, idx: number) => {
                    const cell = cells[idx + 1]; // +1 because first cell is category
                    if (!cell) return;

                    const isOriginallyDash = nivel === "-";
                    const isSelected = selectedNiveles[idx] && selectedNiveles[idx].includes(nivel);

                    if (isOriginallyDash || isSelected) {
                        // Show original value
                        const originalText = cell.getAttribute("data-original-text");
                        if (originalText !== null) {
                            cell.textContent = originalText;
                        }
                        cell.classList.remove("bg-muted/30");
                        
                        // If this level has a real value (not "-"), it's not filtered
                        if (!isOriginallyDash) {
                            allNivelesFiltered = false;
                        }
                    } else {
                        // Value is filtered - show as "-"
                        if (!cell.hasAttribute("data-original-text")) {
                            cell.setAttribute("data-original-text", cell.textContent || "");
                        }
                        cell.textContent = "-";
                        cell.classList.add("bg-muted/30");
                    }
                });

                // Determine if row should be hidden:
                // 1. Hide if category is not selected
                // 2. Hide if ALL visible cells show "-" (no meaningful information)
                
                let shouldHide = false;
                
                if (!categoriaSelected) {
                    // Category not selected - hide row
                    shouldHide = true;
                } else {
                    // Category is selected - check if ALL visible cells show "-"
                    // This includes both the category cell and all subcategory cells
                    let hasVisibleContent = false;
                    
                    // Check all cells in the row
                    for (let i = 0; i < cells.length; i++) {
                        const cellText = cells[i].textContent?.trim();
                        if (cellText && cellText !== "-") {
                            hasVisibleContent = true;
                            break;
                        }
                    }
                    
                    // Hide if no cell has visible content (all show "-")
                    if (!hasVisibleContent) {
                        shouldHide = true;
                    }
                }
                
                el.style.display = shouldHide ? "none" : "";
            });
        }

        function updateCascadingOptions() {
            // Get visible rows
            const visibleRows: HTMLElement[] = [];
            tableRows.forEach((row) => {
                if ((row as HTMLElement).style.display !== "none") {
                    visibleRows.push(row as HTMLElement);
                }
            });

            // Update ONLY subcategory (nivel) dropdowns — NEVER category
            document
                .querySelectorAll("[data-nivel-index]")
                .forEach((dropdown) => {
                    const nivelIndex = parseInt(
                        (dropdown as HTMLElement).dataset.nivelIndex!,
                    );

                    // Collect visible values for this level by reading actual cell content
                    const visibleValues = new Set<string>();
                    visibleRows.forEach((row) => {
                        // Get all cells in this row
                        const cells = row.querySelectorAll("td");
                        // nivelIndex + 1 because first cell (index 0) is category
                        const cell = cells[nivelIndex + 1];
                        
                        if (cell) {
                            const cellText = cell.textContent?.trim();
                            // Only add if cell has visible content (not "-" or empty)
                            if (cellText && cellText !== "-") {
                                visibleValues.add(cellText);
                            }
                        }
                    });

                    // Show/hide ONLY .filter-option elements
                    dropdown
                        .querySelectorAll(".filter-option")
                        .forEach((option) => {
                            const checkbox = option.querySelector(
                                "input",
                            ) as HTMLInputElement;
                            const value = checkbox.dataset.value!;
                            (option as HTMLElement).style.display =
                                visibleValues.has(value) ? "" : "none";
                        });

                    // Update "Todos" checkbox for this nivel
                    updateAllCheckbox(`nivel${nivelIndex}`);
                });
        }

        // Reset button logic
        const resetButton = document.getElementById("reset-filters-button");
        if (resetButton) {
            resetButton.addEventListener("click", () => {
                // Check all individual checkboxes
                document.querySelectorAll(".filter-checkbox").forEach((cb) => {
                    (cb as HTMLInputElement).checked = true;
                });

                // Check and reset all "Todos" checkboxes
                document.querySelectorAll(".filter-all").forEach((cb) => {
                    const input = cb as HTMLInputElement;
                    input.checked = true;
                    input.indeterminate = false;
                });

                // Hide all dropdowns
                filterDropdowns.forEach((d) => {
                    d.classList.add("hidden");
                    // Reset positioning
                    (d as HTMLElement).style.position = "";
                    (d as HTMLElement).style.top = "";
                    (d as HTMLElement).style.left = "";
                });

                // Re-apply filters to show everything
                applyFilters();
                updateCascadingOptions();
            });
        }

        // Initialize
        applyFilters();
    }

    document.addEventListener("astro:page-load", setupFilters);
</script>
