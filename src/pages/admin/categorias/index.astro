const { db } = Astro.locals;
import MainLayout from "@/layouts/MainLayout.astro";
import { getSession } from "auth-astro/server";

const session = await getSession(Astro.request);
const user = session?.user;

if (!user) {
    return Astro.redirect("/login");
}

// Fetch all categories with their subcategories (deep nesting)
const categories = await db.categoria.findMany({
    orderBy: { nombre: "asc" },
    include: {
        subcategoria_categorias: {
            include: {
                subcategoria: {
                    include: {
                        parent_subcategoria: true,
                        subcategorias: {
                            include: {
                                subcategorias: {
                                    include: {
                                        subcategorias: {
                                            include: {
                                                subcategorias: {
                                                    include: {
                                                        subcategorias: true,
                                                    },
                                                },
                                            },
                                        },
                                    },
                                },
                            },
                        },
                    },
                },
            },
        },
    },
});

// Build hierarchical structure with recursive approach
interface CategoryRow {
    categoria: string;
    niveles: string[];
    showCategoria: boolean;
}

const rows: CategoryRow[] = [];
const MAX_LEVELS = 10; // Support up to 10 levels of subcategories

// Recursive function to traverse subcategory tree
function traverseSubcategories(
    categoria: string,
    subcategory: any,
    currentPath: string[],
    level: number,
) {
    const newPath = [...currentPath, subcategory.nombre];

    if (subcategory.subcategorias && subcategory.subcategorias.length > 0) {
        // Has children, continue traversing
        const sortedChildren = subcategory.subcategorias.sort(
            (a: any, b: any) => a.nombre.localeCompare(b.nombre),
        );
        sortedChildren.forEach((child: any) => {
            traverseSubcategories(categoria, child, newPath, level + 1);
        });
    } else {
        // Leaf node, create row
        const niveles = new Array(MAX_LEVELS).fill("-");
        newPath.forEach((name, idx) => {
            niveles[idx] = name;
        });
        rows.push({
            categoria,
            niveles,
            showCategoria: true,
        });
    }
}

categories.forEach((cat) => {
    const subcats = cat.subcategoria_categorias.map((sc) => sc.subcategoria);

    // Get only level 1 subcategories (those without parent)
    const level1Subs = subcats
        .filter((s) => s.parent_subcategoriaId === null)
        .sort((a, b) => a.nombre.localeCompare(b.nombre));

    if (level1Subs.length === 0) {
        // Category with no subcategories
        const niveles = new Array(MAX_LEVELS).fill("-");
        rows.push({
            categoria: cat.nombre,
            niveles,
            showCategoria: true,
        });
    } else {
        level1Subs.forEach((sub1) => {
            traverseSubcategories(cat.nombre, sub1, [], 0);
        });
    }
});

// Mark rows to avoid repetition for each column independently
interface DisplayRow extends CategoryRow {
    showNiveles: boolean[];
}

const displayRows: DisplayRow[] = rows.map((row) => ({
    ...row,
    showNiveles: new Array(MAX_LEVELS).fill(true),
}));

// Track last values for each column
let lastCategoria = "";
const lastNiveles = new Array(MAX_LEVELS).fill("");

displayRows.forEach((row) => {
    // Check categoria
    if (row.categoria === lastCategoria) {
        row.showCategoria = false;
    } else {
        lastCategoria = row.categoria;
        row.showCategoria = true;
        // Reset nivel tracking when category changes
        lastNiveles.fill("");
    }

    // Check each nivel
    row.niveles.forEach((nivel, idx) => {
        if (nivel === lastNiveles[idx]) {
            row.showNiveles[idx] = false;
        } else {
            lastNiveles[idx] = nivel;
            row.showNiveles[idx] = true;
            // Reset subsequent levels when this level changes
            for (let i = idx + 1; i < MAX_LEVELS; i++) {
                lastNiveles[i] = "";
            }
        }
    });
});

// Determine actual max level used
let maxLevelUsed = 0;
displayRows.forEach((row) => {
    for (let i = 0; i < row.niveles.length; i++) {
        if (row.niveles[i] !== "-") {
            maxLevelUsed = Math.max(maxLevelUsed, i + 1);
        }
    }
});

// Collect unique values for filters
const uniqueCategorias = Array.from(
    new Set(displayRows.map((r) => r.categoria)),
).sort();

const uniqueNiveles: string[][] = [];
for (let i = 0; i < maxLevelUsed; i++) {
    const unique = Array.from(
        new Set(displayRows.map((r) => r.niveles[i]).filter((v) => v !== "-")),
    ).sort();
    uniqueNiveles.push(unique);
}
