---
import MainLayout from "@/layouts/MainLayout.astro";
import { prisma } from "@/lib/db";

const empresas = await prisma.empresa.findMany({
  orderBy: { nombre: "asc" },
  include: {
    _count: {
      select: { usuarios: true },
    },
  },
});
---

<MainLayout title="Administración de Usuarios">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-xl font-bold mb-4">Selecciona una empresa</h1>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
    >
      {
        empresas.map((empresa) => (
          <a
            href={`/admin/usuarios/${empresa.slug}`}
            data-astro-reload
            class="company-card block p-6 bg-card border rounded-lg text-center font-semibold text-card-foreground group focus:outline-none"
          >
            <div class="flex flex-col items-center gap-2">
              <span>{empresa.nombre}</span>
              {empresa._count.usuarios > 0 && (
                <span class="count-text text-xs font-normal text-muted-foreground">
                  {empresa._count.usuarios}{" "}
                  {empresa._count.usuarios === 1 ? "usuario" : "usuarios"}
                </span>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </div>
  <div class="max-w-7xl mx-auto mt-12 mb-20" id="bulk-upload-section">
    <h2 class="text-xl font-bold mb-4">Carga masiva de usuarios</h2>
    <div class="bg-card border rounded-lg p-6 shadow-sm">
      <p class="text-sm text-muted-foreground mb-4">
        Sube un archivo CSV con la estructura: <code
          class="bg-muted px-1 py-0.5 rounded"
          >nombres,apellidos,mail,empresa_slug,rol_nombre</code
        >
      </p>

      <form id="bulk-upload-form" class="space-y-4">
        <div
          id="drop-zone"
          class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-8 text-center hover:bg-muted/50 transition-colors cursor-pointer relative"
        >
          <div class="flex flex-col items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-upload text-muted-foreground h-8 w-8 mb-2"
              ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
              ></path><polyline points="17 8 12 3 7 8"></polyline><line
                x1="12"
                x2="12"
                y1="3"
                y2="15"></line></svg
            >
            <p class="text-sm font-medium">
              Arrastre su archivo CSV aquí o haga clic para seleccionar
            </p>
            <p class="text-xs text-muted-foreground">Solo archivos .csv</p>
          </div>
          <!-- Selected file preview -->
          <div
            id="file-preview"
            class="mt-4 hidden text-left bg-muted/30 p-2 rounded border border-border items-center justify-between"
          >
            <span id="file-name" class="text-sm font-mono truncate"></span>
            <button
              type="button"
              id="remove-file"
              class="text-muted-foreground hover:text-destructive p-1">✕</button
            >
          </div>
        </div>

        <div class="flex flex-wrap justify-between items-center gap-4 pt-2">
          <div class="flex gap-2">
            <button
              type="button"
              id="select-file-btn"
              class="bg-secondary text-secondary-foreground hover:bg-secondary/90 px-4 py-2 rounded-md text-sm font-semibold transition-colors"
            >
              Seleccionar Archivo
            </button>
            <button
              type="button"
              id="google-drive-btn"
              class="bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-3 py-2 rounded-md flex items-center gap-2 text-sm font-medium transition-colors"
              title="Seleccionar desde Google Drive"
            >
              <img
                src="/Google_Drive_icon.svg"
                width="20"
                height="20"
                alt="Google Drive"
              />
              Google Drive
            </button>
          </div>
          <button
            type="submit"
            id="upload-btn"
            class="bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-2 rounded-md text-sm font-semibold shadow transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            Subir CSV
          </button>
        </div>
        <input type="file" id="csv-input" accept=".csv" class="hidden" />
      </form>
    </div>
  </div>
</MainLayout>

<style>
  .company-card {
    transition: all 0.3s ease;
  }

  .company-card:hover {
    transform: scale(1.05);
    background-color: #881912; /* Vino */
    color: white;
    border-color: #881912;
  }

  /* Hover text color for count */
  .company-card:hover .count-text {
    color: white;
  }

  /* Dark Mode Styles */
  :global(.dark) .company-card:hover {
    background-color: #e5e5e5; /* Gray 200 */
    color: black;
    border-color: #e5e5e5;
  }

  :global(.dark) .company-card:hover .count-text {
    color: black;
  }

  /* Default Dark Mode Count Text: White (User request) */
  :global(.dark) .count-text {
    color: white;
  }
</style>

<script>
  import { toast } from "@/lib/toast";

  declare global {
    interface Window {
      gapi: any;
      google: any;
    }
  }

  const GOOGLE_API_KEY = import.meta.env.PUBLIC_GOOGLE_API_KEY;
  const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
  const GOOGLE_APP_ID = import.meta.env.PUBLIC_GOOGLE_APP_ID;

  // --- DOM REFERENCES ---
  const dropZone = document.getElementById("drop-zone");
  const fileInput = document.getElementById("csv-input") as HTMLInputElement;
  const selectFileBtn = document.getElementById("select-file-btn");
  const googleDriveBtn = document.getElementById("google-drive-btn");
  const uploadBtn = document.getElementById("upload-btn") as HTMLButtonElement;
  const form = document.getElementById("bulk-upload-form") as HTMLFormElement;
  const filePreview = document.getElementById("file-preview");
  const fileNameSpan = document.getElementById("file-name");
  const removeFileBtn = document.getElementById("remove-file");

  let selectedFile: File | null = null;

  // --- GOOGLE DRIVE LOGIC ---
  let tokenClient: any;
  let accessToken: string | null = null;
  let pickerInited = false;
  let gisInited = false;
  const SCOPES = "https://www.googleapis.com/auth/drive.readonly";

  const initGoogleDrive = () => {
    const script1 = document.createElement("script");
    script1.src = "https://apis.google.com/js/api.js";
    script1.async = true;
    script1.defer = true;
    script1.onload = () => {
      window.gapi.load("client:picker", async () => {
        await window.gapi.client.load(
          "https://www.googleapis.com/discovery/v1/apis/drive/v3/rest",
        );
        pickerInited = true;
      });
    };
    document.body.appendChild(script1);

    const script2 = document.createElement("script");
    script2.src = "https://accounts.google.com/gsi/client";
    script2.async = true;
    script2.defer = true;
    script2.onload = () => {
      if (!window.google) return;
      tokenClient = window.google.accounts.oauth2.initTokenClient({
        client_id: GOOGLE_CLIENT_ID,
        scope: SCOPES,
        callback: "", // defined dynamically
      });
      gisInited = true;
    };
    document.body.appendChild(script2);
  };

  const handleAuthClick = () => {
    if (!GOOGLE_API_KEY || !GOOGLE_CLIENT_ID || !GOOGLE_APP_ID) {
      toast.error("Faltan credenciales de Google Drive.");
      return;
    }

    if (accessToken) {
      createPicker();
      return;
    }

    tokenClient.callback = async (response: any) => {
      if (response.error !== undefined) {
        throw response;
      }
      accessToken = response.access_token;
      createPicker();
    };

    if (accessToken === null) {
      tokenClient.requestAccessToken({ prompt: "consent" });
    } else {
      tokenClient.requestAccessToken({ prompt: "" });
    }
  };

  const createPicker = () => {
    if (!pickerInited || (!accessToken && !gisInited)) {
      toast.error("Google API no está lista aún.");
      return;
    }

    const view = new window.google.picker.DocsView();
    view.setIncludeFolders(true);
    view.setMimeTypes("text/csv,application/vnd.ms-excel,text/plain"); // Try to restrict to CSV-like
    view.setSelectFolderEnabled(false);
    view.setMode(window.google.picker.DocsViewMode.LIST);

    const picker = new window.google.picker.PickerBuilder()
      .enableFeature(window.google.picker.Feature.NAV_HIDDEN)
      .setAppId(GOOGLE_APP_ID)
      .setOAuthToken(accessToken!)
      .addView(view)
      .setDeveloperKey(GOOGLE_API_KEY)
      .setCallback(pickerCallback)
      .build();
    picker.setVisible(true);
  };

  const pickerCallback = async (data: any) => {
    if (data.action === window.google.picker.Action.PICKED) {
      const doc = data[window.google.picker.Response.DOCUMENTS][0];
      const fileId = doc[window.google.picker.Document.ID];
      const name = doc[window.google.picker.Document.NAME];
      const mimeType = doc[window.google.picker.Document.MIME_TYPE];

      // Basic check on name extension since MIME types for CSV vary wildly
      if (!name.toLowerCase().endsWith(".csv")) {
        toast.error("Por favor selecciona un archivo .csv");
        return;
      }

      toast.info(`Descargando ${name}...`);

      try {
        const response = await fetch(
          `https://www.googleapis.com/drive/v3/files/${fileId}?alt=media`,
          { headers: { Authorization: `Bearer ${accessToken}` } },
        );

        if (!response.ok) throw new Error("Error al descargar archivo");

        const blob = await response.blob();
        const file = new File([blob], name, { type: mimeType });
        setFile(file);
      } catch (e) {
        console.error(e);
        toast.error("Error al obtener el archivo desde Drive.");
      }
    }
  };

  // --- FILE HANDLING ---
  const setFile = (file: File) => {
    if (!file.name.toLowerCase().endsWith(".csv")) {
      toast.error("Solo se permiten archivos .csv");
      return;
    }

    selectedFile = file;
    if (fileNameSpan) fileNameSpan.textContent = file.name;
    if (filePreview) {
      filePreview.classList.remove("hidden");
      filePreview.classList.add("flex");
    }
    uploadBtn.disabled = false;
    toast.success("Archivo seleccionado listo para subir.");
  };

  const clearFile = () => {
    selectedFile = null;
    if (fileInput) fileInput.value = ""; // Reset input
    if (filePreview) {
      filePreview.classList.add("hidden");
      filePreview.classList.remove("flex");
    }
    uploadBtn.disabled = true;
  };

  // --- EVENT LISTENERS ---

  // Init Drive Scripts on load
  initGoogleDrive();

  // Select Button -> Trigger Input
  selectFileBtn?.addEventListener("click", () => fileInput.click());

  // Input Change
  fileInput?.addEventListener("change", (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files && files.length > 0) {
      setFile(files[0]);
    }
  });

  // Drive Button
  googleDriveBtn?.addEventListener("click", handleAuthClick);

  // Remove Button
  removeFileBtn?.addEventListener("click", clearFile);

  // Drop Zone
  if (dropZone) {
    dropZone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropZone.classList.add("bg-muted/50", "border-primary");
    });
    dropZone.addEventListener("dragleave", (e) => {
      e.preventDefault();
      dropZone.classList.remove("bg-muted/50", "border-primary");
    });
    dropZone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropZone.classList.remove("bg-muted/50", "border-primary");
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        setFile(e.dataTransfer.files[0]);
      }
    });
    dropZone.addEventListener("click", (e) => {
      // Avoid triggering if clicking remove button inside (though it's in a separate div now)
      if (!(e.target as HTMLElement).closest("#remove-file")) {
        fileInput.click();
      }
    });
  }

  // Submit Form
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!selectedFile) {
      toast.error("Por favor selecciona un archivo.");
      return;
    }

    uploadBtn.disabled = true;
    uploadBtn.innerHTML = `<span class="animate-spin mr-2 inline-block">⏳</span> Procesando...`;

    const formData = new FormData();
    formData.append("file", selectedFile);

    try {
      const response = await fetch("/api/admin/usuarios/import-csv", {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      if (!response.ok) {
        let errorMessage = result.error || "Error al procesar el archivo";
        let detailedMessage = "";

        if (result.error === "Invalid CSV structure" && result.details) {
          const { missing, found, required } = result.details;
          errorMessage = "Estructura de CSV inválida";

          if (found.length === 0) {
            detailedMessage =
              "<strong>Error:</strong> El archivo no contiene ninguna de las columnas necesarias.";
          } else {
            detailedMessage = `
              <div class="mt-2 space-y-1">
                <p><strong>Faltan ${missing.length} columnas:</strong></p>
                <ul class="list-disc list-inside text-xs opacity-90 pl-2">
                  ${missing.map((col: string) => `<li>${col}</li>`).join("")}
                </ul>
                <p class="mt-2 text-xs italic">Columnas encontradas: ${found.join(", ")}</p>
              </div>
            `;
          }
        } else if (result.error === "Invalid CSV format") {
          detailedMessage = `<strong>Error de formato:</strong> ${result.details}`;
        } else if (result.details) {
          detailedMessage = `<p>${result.details}</p>`;
        }

        toast.show({
          message: detailedMessage
            ? `${errorMessage}<br/>${detailedMessage}`
            : errorMessage,
          type: "error",
          allowHtml: true,
          duration: 0, // Persistent until closed
          closeable: true,
        });

        uploadBtn.disabled = false;
        uploadBtn.textContent = "Subir CSV";
        return;
      }

      // Success UI Update
      toast.success(
        `Proceso completado. Exitosos: ${result.success}, Fallidos: ${result.failed}`,
      );

      if (result.errors && result.errors.length > 0) {
        console.warn("Errores de importación:", result.errors);

        const errorSummary = `
          <div class="mt-2">
            <p><strong>Hubo ${result.errors.length} errores en las filas:</strong></p>
            <ul class="list-disc list-inside text-xs opacity-90 pl-2 max-h-32 overflow-y-auto">
              ${result.errors
                .slice(0, 5)
                .map((err: any) => `<li>Fila ${err.row}: ${err.message}</li>`)
                .join("")}
              ${result.errors.length > 5 ? `<li>... y ${result.errors.length - 5} más</li>` : ""}
            </ul>
          </div>
        `;

        toast.show({
          message: errorSummary,
          type: "warning",
          allowHtml: true,
          duration: 8000,
          closeable: true,
        });
      }

      if (result.success > 0) {
        setTimeout(() => {
          window.location.reload();
        }, 5000); // More time to read errors
      } else {
        uploadBtn.disabled = false;
        uploadBtn.textContent = "Subir CSV";
      }
    } catch (error: any) {
      console.error(error);
      toast.error(`Error de red o servidor: ${error.message}`, {
        duration: 0,
        closeable: true,
      });
      uploadBtn.disabled = false;
      uploadBtn.textContent = "Subir CSV";
    }
  });
</script>
