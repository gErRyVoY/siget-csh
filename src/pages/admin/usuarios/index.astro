---
import MainLayout from "@/layouts/MainLayout.astro";
import { prisma } from "@/lib/db";

const empresas = await prisma.empresa.findMany({
  orderBy: { nombre: "asc" },
  include: {
    _count: {
      select: { usuarios: true },
    },
  },
});
---

<MainLayout title="Administración de Usuarios">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Selecciona una Empresa</h1>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
    >
      {
        empresas.map((empresa) => (
          <a
            href={`/admin/usuarios/${empresa.slug}`}
            data-astro-reload
            class="block p-6 bg-card border rounded-lg text-center font-semibold text-card-foreground transition-transform transform hover:scale-105 hover:bg-secondary hover:text-secondary-foreground focus:outline-none focus:ring-2 focus:ring-secondary"
          >
            <div class="flex flex-col items-center gap-2">
              <span>{empresa.nombre}</span>
              {empresa._count.usuarios > 0 && (
                <span class="text-xs font-normal text-muted-foreground">
                  {empresa._count.usuarios}{" "}
                  {empresa._count.usuarios === 1 ? "usuario" : "usuarios"}
                </span>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</MainLayout>
