---
import MainLayout from "@/layouts/MainLayout.astro";
import { prisma } from "@/lib/db";
import type { Usuario, Empresa, Rol } from "@prisma/client";
import { getSession } from "auth-astro/server";

const { id } = Astro.params;
const session = await getSession(Astro.request);

const [user, empresas, roles, secciones] = await Promise.all([
  prisma.usuario.findUnique({
    where: { id: parseInt(id as string, 10) },
    include: { 
      empresa: true, 
      rol: { include: { permisos_seccion: true } },
      permisos_seccion: true 
    },
  }),
  prisma.empresa.findMany({ orderBy: { nombre: "asc" } }),
  prisma.rol.findMany({ orderBy: { rol: "asc" } }),
  prisma.seccion.findMany({ orderBy: { grupo: "asc", nombre: "asc" } })
]);

if (!user) {
  return Astro.redirect("/404");
}

/* --- PERMISSIONS LOGIC --- */
const FULL_EDIT_ROLES = [
  "Director CSH",
  "Ingeniero soporte 3",
  "Desarrollador",
];
const RESTRICTED_EDIT_ROLES = [
  "Ingeniero soporte 1",
  "Ingeniero soporte 2",
  "Auditor CSH",
  "Ingeniero Hubspot",
];
const MARKETING_TEAM_ROLES = [
  "Director Marketing",
  "Diseñador",
  "Community manager",
  "Editor",
];

const currentUserRole = session?.user?.rol?.rol || "";

// Check capabilities
const isFullEditor = FULL_EDIT_ROLES.includes(currentUserRole);
const isRestrictedEditor = RESTRICTED_EDIT_ROLES.includes(currentUserRole);

// Special Marketing Logic
const isMarketingDirector = currentUserRole === "Director Marketing";
const isMarketingTeamMember = MARKETING_TEAM_ROLES.includes(currentUserRole);

// Target User Properties
const targetUserNivelSoporte = user.rol?.nivel_soporte;
const targetIsMarketing = targetUserNivelSoporte === "Marketing";

// Can Edit?
const canFullEdit = isFullEditor;
const canRestrictedEdit = isRestrictedEditor;
const canMarketingEdit = isMarketingDirector && targetIsMarketing;

const canEdit = canFullEdit || canRestrictedEdit || canMarketingEdit;

// Field Restrictions
const isEmpresaReadOnly = !canFullEdit; // Only Full Editors can change Empresa (implied from "excepto empresa" for Mkt Director)
const isRoleSelectFiltered = isMarketingTeamMember;
const areAuditorChecksHidden = isMarketingTeamMember;

/* -------------------------- */

const concatenatedName = `${user.nombres} ${user.apellidos}`;

const formattedLastLogin = new Date(user.ultimo_login).toLocaleString("es-MX", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "numeric",
  minute: "numeric",
  second: "numeric",
  hour12: true,
});

const groupedEmpresas: { [key: string]: Empresa[] } = {
  Oficina: [],
  Social: [],
  Campus: [],
};
empresas.forEach((empresa) => {
  if (empresa.tipo === "Oficina") groupedEmpresas["Oficina"].push(empresa);
  else if (empresa.tipo === "Social") groupedEmpresas["Social"].push(empresa);
  else groupedEmpresas["Campus"].push(empresa);
});
const groupOrder = ["Oficina", "Social", "Campus"];

// Filter Roles for Marketing Team
const displayedRoles = isRoleSelectFiltered
  ? roles.filter((r) => MARKETING_TEAM_ROLES.includes(r.rol))
  : roles;

// Safely stringify the schedule for the client-side script
const horarioString = JSON.stringify(user.horario_disponibilidad);

// Permisos (Secciones Híbridas)
const userRoleSections = user.rol?.permisos_seccion.filter(ps => ps.activo).map(ps => ps.seccionId) || [];
const userSpecificSectionsActive = user.permisos_seccion.filter(ps => ps.activo).map(ps => ps.seccionId);

// Agrupar secciones para UI
const groupedSecciones: { [key: string]: typeof secciones } = {};
secciones.forEach(sec => {
  const group = sec.grupo || 'Otros';
  if (!groupedSecciones[group]) groupedSecciones[group] = [];
  groupedSecciones[group].push(sec);
});
---

<MainLayout title={`Editar Usuario: ${concatenatedName}`}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Editar usuario</h1>
    <form
      id="edit-user-form"
      class="bg-card border rounded-lg p-4 space-y-6"
      data-user-id={user.id}
      data-horario={horarioString}
    >
      <fieldset disabled={!canEdit} class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-muted-foreground"
              >Nombre completo</label
            >
            <p class="mt-1 text-lg">{concatenatedName}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-muted-foreground"
              >Email</label
            >
            <p class="mt-1 text-lg">{user.mail}</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-muted-foreground"
              >Último inicio de sesión</label
            >
            <p class="mt-1 text-lg">{formattedLastLogin}</p>
          </div>
        </div>
        <div class="border-t border-border"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="empresaId" class="block text-sm font-medium"
              >Empresa</label
            >
            <select
              id="empresaId"
              name="empresaId"
              class="mt-1 block w-full rounded-md border-border bg-input p-2 accent-secondary focus:outline-none focus:ring-1 focus:ring-secondary disabled:opacity-50 disabled:cursor-not-allowed"
              disabled={!canEdit || isEmpresaReadOnly}
            >
              {
                groupOrder.map((groupName) => (
                  <optgroup label={groupName}>
                    {groupedEmpresas[groupName].map((empresa) => (
                      <option
                        value={empresa.id}
                        selected={empresa.id === user.empresaId}
                      >
                        {empresa.nombre}
                      </option>
                    ))}
                  </optgroup>
                ))
              }
            </select>
          </div>
          <div>
            <label for="rolId" class="block text-sm font-medium">Rol</label>
            <select
              id="rolId"
              name="rolId"
              class="mt-1 block w-full rounded-md border-border bg-input p-2 accent-secondary focus:outline-none focus:ring-1 focus:ring-secondary disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {
                displayedRoles.map((rol) => (
                  <option value={rol.id} selected={rol.id === user.rolId}>
                    {rol.rol}
                  </option>
                ))
              }
            </select>
          </div>
        </div>

        <!-- NEW CHECKBOX LAYOUT -->
        <div
          class="grid grid-cols-2 md:flex md:flex-row md:items-center md:gap-6 pt-2"
        >
          <!-- Left Group (Mobile Col 1) -->
          <div class="flex flex-col gap-4 md:flex-row md:gap-6">
            <div class="flex items-center">
              <input
                type="checkbox"
                id="activo"
                name="activo"
                class="h-4 w-4 rounded border-border text-primary focus:ring-primary disabled:opacity-50"
                checked={user.activo}
              />
              <label for="activo" class="ml-3 block text-sm font-medium"
                >Activo</label
              >
            </div>
            <div class="flex items-center">
              <input
                type="checkbox"
                id="vacaciones"
                name="vacaciones"
                class="h-4 w-4 rounded border-border text-primary focus:ring-primary disabled:opacity-50"
                checked={user.vacaciones}
              />
              <label for="vacaciones" class="ml-3 block text-sm font-medium"
                >De vacaciones</label
              >
            </div>
          </div>

          <!-- Right Group (Mobile Col 2) -->
          {
            !areAuditorChecksHidden && (
              <div class="flex flex-col gap-4 md:flex-row md:gap-6">
                <div class="flex items-center">
                  <input
                    type="checkbox"
                    id="auditor_docs"
                    name="auditor_docs"
                    class="h-4 w-4 rounded border-border text-primary focus:ring-primary disabled:opacity-50"
                    checked={user.auditor_docs}
                  />
                  <label
                    for="auditor_docs"
                    class="ml-3 block text-sm font-medium"
                  >
                    Auditor de Documentos
                  </label>
                </div>
                <div class="flex items-center">
                  <input
                    type="checkbox"
                    id="auditor_req"
                    name="auditor_req"
                    class="h-4 w-4 rounded border-border text-primary focus:ring-primary disabled:opacity-50"
                    checked={user.auditor_req}
                  />
                  <label
                    for="auditor_req"
                    class="ml-3 block text-sm font-medium"
                  >
                    Auditor de Requisitos
                  </label>
                </div>
              </div>
            )
          }
        </div>
        <!-- END NEW CHECKBOX LAYOUT -->

        <div class="md:col-span-2">
          <label class="block text-sm font-medium"
            >Horario de Disponibilidad</label
          >
          <div
            class="mt-2 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-4"
            id="horarios-container"
          >
            <!-- Horarios Semanales se insertan aquí -->
          </div>
        </div>
        
        <!-- NEW SECCIONES LAYOUT -->
        <div class="border-t border-border mt-8 pt-6">
          <h2 class="text-xl font-bold mb-4">Permisos Híbridos (Secciones)</h2>
          <p class="text-sm text-muted-foreground mb-6">
            Los permisos con etiqueta "Heredado" se obtienen automáticamente del rol establecido. Sin embargo, como administrador puedes otorgar explícitamente acceso a secciones adicionales para este usuario habilitando los interruptores libres.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {Object.entries(groupedSecciones).map(([grupo, secs]) => (
              <div class="bg-card border rounded-lg p-4 shadow-sm">
                <h3 class="text-xs font-semibold text-muted-foreground mb-4 uppercase tracking-wider">{grupo}</h3>
                <div class="space-y-4">
                  {secs.map(seccion => {
                    const isInherited = userRoleSections.includes(seccion.id);
                    const isExplicitlyActive = userSpecificSectionsActive.includes(seccion.id);
                    const isChecked = isInherited || isExplicitlyActive;

                    return (
                      <div class="flex items-center justify-between gap-4">
                        <label for={`sec-${seccion.id}`} class="text-sm cursor-pointer select-none truncate pr-2 flex-1" title={seccion.nombre}>
                          {seccion.nombre}
                        </label>
                        
                        {isInherited ? (
                          <span class="text-[10px] font-medium bg-secondary text-secondary-foreground px-2 py-1 rounded">Heredado</span>
                        ) : (
                          <label class="relative inline-flex items-center cursor-pointer shrink-0" title="Otorgar acceso">
                            <input type="checkbox" id={`sec-${seccion.id}`} class="sr-only peer section-toggle" data-seccion-id={seccion.id} data-usuario-id={user.id} checked={isChecked} disabled={!canEdit} />
                            <div class="w-9 h-5 bg-muted peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary opacity-50 peer-checked:opacity-100 disabled:opacity-30 disabled:cursor-not-allowed"></div>
                          </label>
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>
        <!-- END NEW SECCIONES LAYOUT -->

        {
          canEdit && (
            <div class="flex justify-end pt-4 gap-4">
              <a
                href={`/admin/usuarios/${user.empresa.slug}`}
                class="bg-muted-foreground text-white hover:bg-muted-foreground/80 px-6 py-2 rounded-md text-sm font-semibold transition-colors"
              >
                Volver a la lista
              </a>
              <button
                type="submit"
                class="bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-2 rounded-md text-sm font-semibold"
              >
                Guardar cambios
              </button>
            </div>
          )
        }
      </fieldset>

      {
        !canEdit && (
          <div class="flex justify-end pt-4 gap-4">
            <a
              href={`/admin/usuarios/${user.empresa.slug}`}
              class="bg-muted text-muted-foreground hover:bg-muted/80 px-6 py-2 rounded-md text-sm font-semibold transition-colors"
            >
              Volver a la lista
            </a>
          </div>
        )
      }
    </form>
  </div>
</MainLayout>

<script>
  import { initializeUserEditForm } from "@/scripts/user-edit-form-logic";
  import { toast } from "@/lib/toast";

  document.addEventListener("astro:page-load", () => {
    initializeUserEditForm();

    // Toggle logic for explicit section permissions
    const toggles = document.querySelectorAll('.section-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('change', async (e) => {
        const input = e.target as HTMLInputElement;
        const seccionId = input.dataset.seccionId;
        const usuarioId = input.dataset.usuarioId;
        const activo = input.checked;

        try {
          // Optimistic UI change is natural to the checkbox, so we just run the query
          const res = await fetch('/api/admin/usuarios/secciones', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ usuarioId, seccionId, activo })
          });

          if (!res.ok) {
            throw new Error((await res.json()).message || "Error al actualizar la sección");
          }

          toast.success(activo ? "Permiso otorgado correctamente" : "Permiso retirado correctamente");
        } catch (error) {
          console.error(error);
          input.checked = !activo; // Revert checkbox if it fails
          toast.error(error instanceof Error ? error.message : "No se pudo actualizar el permiso");
        }
      });
    });
  });
</script>
